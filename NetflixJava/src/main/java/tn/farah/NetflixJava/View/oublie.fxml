<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane style="-fx-background-color: rgba(0, 0, 0, 0.75);" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <VBox alignment="TOP_CENTER" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="450.0" prefWidth="550.0" spacing="20.0" style="-fx-background-color: #141414; -fx-background-radius: 10; -fx-border-color: #333333; -fx-border-radius: 10;">
         <padding>
            <Insets bottom="30.0" left="40.0" right="40.0" top="20.0" />
         </padding>
         <children>
            
            <HBox alignment="CENTER_RIGHT" prefHeight="30.0" prefWidth="200.0">
               <children>
                  <Label text="✕" textFill="#b3b3b3" style="-fx-font-size: 20px;">
                     <cursor>
                        <Cursor fx:constant="HAND" />
                     </cursor>
                  </Label>
               </children>
            </HBox>

            <Label text="Mot de passe oublié ?" textFill="WHITE" style="-fx-font-size: 28px; -fx-font-weight: bold;" />

            <Label text="Un email de réinitialisation sera envoyé à votre adresse" textFill="#cccccc" style="-fx-font-size: 15px;" />

            <Region prefHeight="10.0" prefWidth="200.0" />

            <VBox spacing="8.0" maxWidth="400.0">
               <children>
                  <Label text="Adresse Email" textFill="#b3b3b3" style="-fx-font-size: 14px;" />
                  <TextField style="-fx-background-color: #333333; -fx-text-fill: white; -fx-font-size: 16px; -fx-padding: 12; -fx-background-radius: 5;" />
               </children>
            </VBox>

            <HBox alignment="CENTER" maxWidth="350.0" spacing="15.0" style="-fx-background-color: #f9f9f9; -fx-padding: 15 20 15 20; -fx-background-radius: 3; -fx-border-color: #d3d3d3; -fx-border-radius: 3;">
               <children>
                  <CheckBox mnemonicParsing="false" style="-fx-font-size: 14px; -fx-text-fill: #555555;" text="Je ne suis pas un robot">
                     <cursor>
                        <Cursor fx:constant="HAND" />
                     </cursor>
                  </CheckBox>
                  <Region HBox.hgrow="ALWAYS" />
                  <VBox alignment="CENTER">
                     <children>
                        <Label text="♻" textFill="#4a90e2" style="-fx-font-size: 24px;" />
                        <Label text="reCAPTCHA" textFill="#555555" style="-fx-font-size: 10px;" />
                     </children>
                  </VBox>
               </children>
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </HBox>

            <Region prefHeight="10.0" prefWidth="200.0" VBox.vgrow="ALWAYS" />

            <VBox alignment="CENTER" spacing="15.0">
               <children>
                  <Button maxWidth="350.0" mnemonicParsing="false" style="-fx-background-color: #e50914; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px; -fx-padding: 12; -fx-background-radius: 4;" text="Confirmer">
                     <cursor>
                        <Cursor fx:constant="HAND" />
                     </cursor>
                  </Button>

                  <Button maxWidth="350.0" mnemonicParsing="false" style="-fx-background-color: transparent; -fx-border-color: #555555; -fx-text-fill: #b3b3b3; -fx-font-size: 14px; -fx-padding: 8; -fx-border-radius: 4;" text="FERMER">
                     <cursor>
                        <Cursor fx:constant="HAND" />
                     </cursor>
                  </Button>
               </children>
            </VBox>

         </children>
      </VBox>
   </children>
</StackPane>