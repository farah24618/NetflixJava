<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background-color:#0f0f13; -fx-border-color:transparent;" stylesheets="@dark.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.farah.NetflixJava.Controller.AddSaisonnController">

    <VBox maxHeight="Infinity" minHeight="-Infinity" spacing="0" style="-fx-background-color:#0f0f13;">

        <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color:#1a1a22; -fx-border-color:#e50914; -fx-border-width:0 0 2 0; -fx-padding:14 24 14 24;">
            <ImageView fitHeight="51.0" fitWidth="68.0" pickOnBounds="true" preserveRatio="true">
                <image><Image url="@ImagesNet/rakchanetLogo.png" /></image>
            </ImageView>
            <VBox spacing="2">
                <Label style="-fx-font-size:14px; -fx-font-weight:bold; -fx-text-fill:#e50914;" text="RAKCHANET ADMIN" />
                <Label style="-fx-font-size:11px; -fx-text-fill:#888888;" text="Ajouter une nouvelle saison" />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="btnRetour" onAction="#handleRetour" style="-fx-background-color:#e50914; -fx-background-radius:8; -fx-text-fill:white; -fx-font-size:13px; -fx-font-weight:bold; -fx-padding:10 24 10 24; -fx-cursor:hand;" text="Retour" />
            <Button fx:id="btnCancel" onAction="#handleCancel" style="-fx-background-color:transparent; -fx-border-color:#3a3a45; -fx-border-radius:8; -fx-border-width:1; -fx-text-fill:#888888; -fx-font-size:13px; -fx-padding:10 20 10 20; -fx-cursor:hand;" text="Annuler" />
            <Button fx:id="btnSave" onAction="#handleSave" style="-fx-background-color:#e50914; -fx-background-radius:8; -fx-text-fill:white; -fx-font-size:13px; -fx-font-weight:bold; -fx-padding:10 24 10 24; -fx-cursor:hand;" text="✓  Enregistrer la saison" />
        </HBox>

        <HBox spacing="24" style="-fx-padding:24 24 40 24;" VBox.vgrow="ALWAYS">
            
            <VBox spacing="20" HBox.hgrow="ALWAYS">
                <VBox spacing="20" style="-fx-background-color:#1a1a22; -fx-background-radius:10; -fx-border-color:#2a2a35; -fx-border-radius:10; -fx-border-width:1; -fx-padding:20;">
                    <Label style="-fx-font-size:14px; -fx-font-weight:bold; -fx-text-fill:#ffffff;" text="Informations de la saison" />
                    <VBox spacing="8">
                        <Label style="-fx-font-size:12px; -fx-text-fill:#888888; -fx-font-weight:bold;" text="Série associée *" />
                        <ComboBox fx:id="cbSerie" maxWidth="Infinity" promptText="Choisir la série..." style="-fx-background-color:#0f0f13; -fx-border-color:#2a2a35; -fx-border-radius:6; -fx-background-radius:6; -fx-border-width:1; -fx-font-size:13px; -fx-text-fill:#eeeeee; -fx-padding:4;" />
                    </VBox>
              <VBox spacing="8">
                        <Label style="-fx-font-size:12px; -fx-text-fill:#888888; -fx-font-weight:bold;" text="Nom de la saison *" />
                        <TextField fx:id="txtNom" promptText="Saison n°" style="-fx-background-color:#0f0f13; -fx-border-color:#2a2a35; -fx-border-radius:6; -fx-background-radius:6; -fx-border-width:1; -fx-text-fill:#eeeeee; -fx-prompt-text-fill:#444444; -fx-padding:10 12 10 12; -fx-font-size:13px;" />
                    </VBox>
                    <VBox spacing="8">
                        <Label style="-fx-font-size:12px; -fx-text-fill:#888888; -fx-font-weight:bold;" text="Numéro de la saison *" />
                        <TextField fx:id="txtNumeroSaison" promptText="Ex : 1, 2, 3..." style="-fx-background-color:#0f0f13; -fx-border-color:#2a2a35; -fx-border-radius:6; -fx-background-radius:6; -fx-border-width:1; -fx-text-fill:#eeeeee; -fx-prompt-text-fill:#444444; -fx-padding:10 12 10 12; -fx-font-size:13px;" />
                    </VBox>
                </VBox>
            </VBox>

            <VBox minWidth="300" prefWidth="340" spacing="20">
                <VBox spacing="12" style="-fx-background-color:#1a1a22; -fx-background-radius:10; -fx-border-color:#3a3a45; -fx-border-radius:10; -fx-border-width:1; -fx-padding:20;">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label style="-fx-font-size:20px; -fx-text-fill:#e50914;" text="ℹ️" />
                        <Label style="-fx-font-size:13px; -fx-font-weight:bold; -fx-text-fill:#ffffff;" text="Comment ça marche ?" />
                    </HBox>
                    <Label style="-fx-font-size:12px; -fx-text-fill:#aaaaaa;" text="1. Sélectionnez la série..." wrapText="true" />
                    <Label style="-fx-font-size:12px; -fx-text-fill:#aaaaaa;" text="2. Indiquez le numéro..." wrapText="true" />
                    <Label style="-fx-font-size:12px; -fx-text-fill:#aaaaaa;" text="3. Cliquez sur Enregistrer..." wrapText="true" />
                    <Region prefHeight="10" />
                    <Label fx:id="lblStatus" style="-fx-font-size:13px; -fx-font-weight:bold; -fx-text-fill:#4caf50;" text="" wrapText="true" />
                </VBox>
            </VBox>
        </HBox>
    </VBox>
</ScrollPane>
