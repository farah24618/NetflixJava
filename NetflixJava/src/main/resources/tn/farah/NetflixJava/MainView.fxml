<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="900.0" prefWidth="1280.0" style="-fx-background-color: black;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.farah.NetflixJava.Controller.MainViewController">
  

    <!-- ===== MainViewController ===== -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="68.0" style="-fx-background-color: rgba(0,0,0,0.9); -fx-padding: 0 40 0 40;">
            <!-- Logo -->
            <Label text="RAKCHANET" textFill="#e50914">
                <font><Font name="System Bold" size="32.0" /></font>
            </Label>
            <!-- Nav links -->
            <HBox alignment="CENTER_LEFT" spacing="18" style="-fx-padding: 0 0 0 30;" />
            <Region HBox.hgrow="ALWAYS" />
            <!-- Right side actions -->
            <HBox alignment="CENTER" spacing="20">
                <Button fx:id="signInButton" mnemonicParsing="false" onAction="#handleSignIn" prefHeight="35" prefWidth="141.0" style="-fx-background-color: #e50914; -fx-background-radius: 4;" text="Sign In" textFill="WHITE">
                    <font><Font name="System Bold" size="14.0" /></font>
                    <cursor><Cursor fx:constant="HAND" /></cursor>
                </Button>
            </HBox>
        </HBox>
    </top>

    <!-- ===== MAIN SCROLL CONTENT ===== -->
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background: black; -fx-background-color: black; -fx-border-color: black;" vbarPolicy="AS_NEEDED" BorderPane.alignment="CENTER">
            <content>
                <VBox style="-fx-background-color: black;">

                    <!-- ===== HERO SECTION ===== -->
                    <StackPane prefHeight="680.0" prefWidth="1280.0" style="-fx-background-color: linear-gradient(to bottom, #141414 0%, #0a0a0a 100%);                                       -fx-border-color: #222; -fx-border-width: 0 0 8 0;">
					<VBox alignment="CENTER" spacing="24"
      styleClass="hero-section"
      stylesheets="@mainView.css"
      style="-fx-padding: 80 100 80 100;">                          <Label alignment="CENTER" text="Unlimited movies, TV&#10;shows, and more" textFill="WHITE" wrapText="true">
                                <font><Font name="System Bold" size="52.0" /></font>
                            </Label>
                            <Label alignment="CENTER" text="Watch anywhere. Cancel anytime." textFill="WHITE">
                                <font><Font size="26.0" /></font>
                            </Label>
                            <Label alignment="CENTER" text="Ready to watch? Enter your email to create or restart your membership." textFill="WHITE" wrapText="true">
                                <font><Font size="19.0" /></font>
                            </Label>
                            <HBox alignment="CENTER" spacing="10">
                                <TextField fx:id="heroEmailField" prefHeight="60" prefWidth="430" promptText="Email address" style="-fx-background-color: rgba(22,22,22,0.9);                                                   -fx-text-fill: white;                                                   -fx-prompt-text-fill: #aaa;                                                   -fx-border-color: #808080;                                                   -fx-border-width: 1;                                                   -fx-font-size: 16;                                                   -fx-padding: 10 14 10 14;" />
                                <Button fx:id="heroGetStartedButton" onAction="#handleHeroGetStarted" prefHeight="60" prefWidth="200" style="-fx-background-color: #e50914; -fx-background-radius: 4; -fx-font-size: 22;" text="Get Started ›" textFill="WHITE">
                                    <font><Font name="System Bold" size="22.0" /></font>
                                    <cursor><Cursor fx:constant="HAND" /></cursor>
                                </Button>
                            </HBox>
                        </VBox>
                    </StackPane>

                    <!-- ===== FEATURE 1: ENJOY ON TV ===== -->
                    <HBox alignment="CENTER" prefHeight="500" prefWidth="1280" spacing="40" style="-fx-background-color: black; -fx-border-color: #222; -fx-border-width: 0 0 8 0; -fx-padding: 60 80 60 80;">
                        <VBox alignment="CENTER_LEFT" prefWidth="560" spacing="24">
                            <Label text="Enjoy on your TV." textFill="WHITE" wrapText="true">
                                <font><Font name="System Bold" size="50.0" /></font>
                            </Label>
                            <Label text="Watch on Smart TVs, PlayStation, Xbox, Chromecast, Apple TV, Blu-ray players, and more." textFill="WHITE" wrapText="true">
                                <font><Font size="22.0" /></font>
                            </Label>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <!-- TV Image placeholder (replace with actual ImageView with image URL) -->
                        <StackPane prefHeight="380" prefWidth="500" style="-fx-background-color: #1a1a2e; -fx-background-radius: 8;">
                            <Label style="-fx-font-size: 120; -fx-opacity: 0.6;" text="📺" />
                        </StackPane>
                    </HBox>

                    <!-- ===== FEATURE 2: DOWNLOAD ===== -->
                    <HBox alignment="CENTER" prefHeight="500" prefWidth="1280" spacing="40" style="-fx-background-color: black; -fx-border-color: #222; -fx-border-width: 0 0 8 0; -fx-padding: 60 80 60 80;">
                        <!-- Download Image placeholder -->
                        <StackPane prefHeight="380" prefWidth="500" style="-fx-background-color: #1a1a2e; -fx-background-radius: 8;">
                            <Label style="-fx-font-size: 120; -fx-opacity: 0.6;" text="📱" />
                        </StackPane>
                        <Region HBox.hgrow="ALWAYS" />
                        <VBox alignment="CENTER_LEFT" prefWidth="560" spacing="24">
                            <Label text="Download your shows to watch offline." textFill="WHITE" wrapText="true">
                                <font><Font name="System Bold" size="50.0" /></font>
                            </Label>
                            <Label text="Save your favourites easily and always have something to watch." textFill="WHITE" wrapText="true">
                                <font><Font size="22.0" /></font>
                            </Label>
                            <!-- Download animation card -->
                            <HBox alignment="CENTER_LEFT" spacing="14" style="-fx-background-color: black;                                          -fx-border-color: #e50914;                                          -fx-border-width: 2;                                          -fx-border-radius: 12;                                          -fx-background-radius: 12;                                          -fx-padding: 12 20 12 16;">
                                <Label style="-fx-font-size: 42;" text="🎬" />
                                <VBox spacing="3">
                                    <Label text="Stranger Things" textFill="WHITE">
                                        <font><Font name="System Bold" size="15.0" /></font>
                                    </Label>
                                    <Label text="Downloading..." textFill="#0071eb">
                                        <font><Font size="13.0" /></font>
                                    </Label>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS" />
                                <Label style="-fx-font-size: 26;" text="⬇" textFill="#e50914" />
                            </HBox>
                        </VBox>
                    </HBox>

                    <!-- ===== FEATURE 3: WATCH EVERYWHERE ===== -->
                    <HBox alignment="CENTER" prefHeight="500" prefWidth="1280" spacing="40" style="-fx-background-color: black; -fx-border-color: #222; -fx-border-width: 0 0 8 0; -fx-padding: 60 80 60 80;">
                        <VBox alignment="CENTER_LEFT" prefWidth="560" spacing="24">
                            <Label text="Watch everywhere." textFill="WHITE" wrapText="true">
                                <font><Font name="System Bold" size="50.0" /></font>
                            </Label>
                            <Label text="Stream unlimited movies and TV shows on your phone, tablet, laptop, and TV." textFill="WHITE" wrapText="true">
                                <font><Font size="22.0" /></font>
                            </Label>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <!-- Devices illustration placeholder -->
                        <StackPane prefHeight="380" prefWidth="500" style="-fx-background-color: #0d1117; -fx-background-radius: 8;">
                            <HBox alignment="CENTER" spacing="10">
                                <Label style="-fx-font-size: 80; -fx-opacity: 0.7;" text="💻" />
                                <Label style="-fx-font-size: 60; -fx-opacity: 0.7;" text="📱" />
                                <Label style="-fx-font-size: 90; -fx-opacity: 0.7;" text="🖥" />
                            </HBox>
                        </StackPane>
                    </HBox>

                    <!-- ===== FEATURE 4: KIDS ===== -->
                    <HBox alignment="CENTER" prefHeight="500" prefWidth="1280" spacing="40" style="-fx-background-color: black; -fx-border-color: #222; -fx-border-width: 0 0 8 0; -fx-padding: 60 80 60 80;">
                        <!-- Kids image placeholder -->
                        <StackPane prefHeight="380" prefWidth="500" style="-fx-background-color: #1a0030; -fx-background-radius: 8;">
                            <Label style="-fx-font-size: 100; -fx-opacity: 0.7;" text="👶🎈" />
                        </StackPane>
                        <Region HBox.hgrow="ALWAYS" />
                        <VBox alignment="CENTER_LEFT" prefWidth="560" spacing="24">
                            <Label text="Create profiles for kids." textFill="WHITE" wrapText="true">
                                <font><Font name="System Bold" size="50.0" /></font>
                            </Label>
                            <Label text="Send kids on adventures with their favourite characters in a space made just for them — free with your membership." textFill="WHITE" wrapText="true">
                                <font><Font size="22.0" /></font>
                            </Label>
                        </VBox>
                    </HBox>

                    <!-- ===== FAQ SECTION ===== -->
                    <VBox spacing="0" style="-fx-background-color: black; -fx-border-color: #222; -fx-border-width: 0 0 8 0; -fx-padding: 70 200 70 200;">
                        <Label text="Frequently Asked Questions" textFill="WHITE">
                            <font><Font name="System Bold" size="50.0" /></font>
                            <VBox.margin><Insets bottom="20" /></VBox.margin>
                        </Label>

                        <!-- FAQ 1 -->
                        <TitledPane animated="false" expanded="false" style="-fx-background-color: #303030; -fx-text-fill: white; -fx-border-color: #555; -fx-border-width: 0 0 2 0;" stylesheets="@Style.css" text="What is RAKCHANET?">
                            <font><Font name="System Bold" size="22.0" /></font>
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                            <content>
                                <AnchorPane style="-fx-background-color: #303030; -fx-padding: 30 25 30 25;">
                                    <Label text="RAKCHANET is a streaming service that offers a wide variety of award-winning TV shows, movies, anime, documentaries, and more on thousands of internet-connected devices.&#10;&#10;You can watch as much as you want, whenever you want without a single commercial – all for one low monthly price. There's always something new to discover and new TV shows and movies are added every week!" textFill="WHITE" wrapText="true" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
                                        <font><Font size="22.0" /></font>
                                    </Label>
                                </AnchorPane>
                            </content>
                        </TitledPane>
                        <Region prefHeight="3" />

                        <!-- FAQ 2 -->
                        <TitledPane animated="false" expanded="false" style="-fx-background-color: #303030; -fx-text-fill: white; -fx-border-color: #555; -fx-border-width: 0 0 2 0;" stylesheets="@Style.css" text="How much does RAKCHANET cost?">
                            <font><Font name="System Bold" size="22.0" /></font>
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                            <content>
                                <AnchorPane style="-fx-background-color: #303030; -fx-padding: 30 25 30 25;">
                                    <Label text="Watch RAKCHANET on your smartphone, tablet, Smart TV, laptop, or streaming device, all for one fixed monthly fee. Plans range from €4.99 to €17.99 a month. No extra costs, no contracts." textFill="WHITE" wrapText="true" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
                                        <font><Font size="22.0" /></font>
                                    </Label>
                                </AnchorPane>
                            </content>
                        </TitledPane>
                        <Region prefHeight="3" />

                        <!-- FAQ 3 -->
                        <TitledPane animated="false" expanded="false" style="-fx-background-color: #303030; -fx-text-fill: white; -fx-border-color: #555; -fx-border-width: 0 0 2 0;" stylesheets="@Style.css" text="Where can I watch?">
                            <font><Font name="System Bold" size="22.0" /></font>
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                            <content>
                                <AnchorPane style="-fx-background-color: #303030; -fx-padding: 30 25 30 25;">
                                    <Label text="Watch anywhere, anytime. Sign in with your RAKCHANET account to watch instantly on the web at rakchanet.com from your personal computer or on any internet-connected device that offers the RAKCHANET app, including smart TVs, smartphones, tablets, streaming media players and game consoles.&#10;&#10;You can also download your favourite shows with the iOS, Android, or Windows 10 app." textFill="WHITE" wrapText="true" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
                                        <font><Font size="22.0" /></font>
                                    </Label>
                                </AnchorPane>
                            </content>
                        </TitledPane>
                        <Region prefHeight="3" />

                        <!-- FAQ 4 -->
                        <TitledPane animated="false" expanded="false" style="-fx-background-color: #303030; -fx-text-fill: white; -fx-border-color: #555; -fx-border-width: 0 0 2 0;" stylesheets="@Style.css" text="How do I cancel?">
                            <font><Font name="System Bold" size="22.0" /></font>
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                            <content>
                                <AnchorPane style="-fx-background-color: #303030; -fx-padding: 30 25 30 25;">
                                    <Label text="RAKCHANET is flexible. There are no pesky contracts and no commitments. You can easily cancel your account online in two clicks. There are no cancellation fees – start or stop your account anytime." textFill="WHITE" wrapText="true" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
                                        <font><Font size="22.0" /></font>
                                    </Label>
                                </AnchorPane>
                            </content>
                        </TitledPane>
                        <Region prefHeight="3" />

                        <!-- FAQ 5 -->
                        <TitledPane animated="false" expanded="false" style="-fx-background-color: #303030; -fx-text-fill: white; -fx-border-color: #555; -fx-border-width: 0 0 2 0;" stylesheets="@Style.css" text="What can I watch on RAKCHANET?">
                            <font><Font name="System Bold" size="22.0" /></font>
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                            <content>
                                <AnchorPane style="-fx-background-color: #303030; -fx-padding: 30 25 30 25;">
                                    <Label text="RAKCHANET has an extensive library of feature films, documentaries, TV shows, anime, award-winning RAKCHANET originals, and more. Watch as much as you want, anytime you want." textFill="WHITE" wrapText="true" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
                                        <font><Font size="22.0" /></font>
                                    </Label>
                                </AnchorPane>
                            </content>
                        </TitledPane>
                        <Region prefHeight="3" />

                        <!-- FAQ 6 -->
                        <TitledPane animated="false" expanded="false" style="-fx-background-color: #303030; -fx-text-fill: white; -fx-border-color: #555; -fx-border-width: 0 0 2 0;" stylesheets="@Style.css" text="Is RAKCHANET good for kids?">
                            <font><Font name="System Bold" size="22.0" /></font>
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                            <content>
                                <AnchorPane style="-fx-background-color: #303030; -fx-padding: 30 25 30 25;">
                                    <Label text="The RAKCHANET Kids experience is included in your membership to give parents control while kids enjoy family-friendly TV shows and movies in their own space.&#10;&#10;Kids profiles come with PIN-protected parental controls that let you restrict the maturity rating of content kids can watch and block specific titles you don't want kids to see." textFill="WHITE" wrapText="true" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
                                        <font><Font size="22.0" /></font>
                                    </Label>
                                </AnchorPane>
                            </content>
                        </TitledPane>

                        <!-- CTA below FAQ -->
                        <VBox alignment="CENTER" spacing="16" style="-fx-padding: 50 0 10 0;">
                            <Label alignment="CENTER" text="Ready to watch? Enter your email to create or restart your membership." textFill="WHITE" wrapText="true">
                                <font><Font size="19.0" /></font>
                            </Label>
                            <HBox alignment="CENTER" spacing="10">
                                <TextField fx:id="faqEmailField" prefHeight="60" prefWidth="430" promptText="Email address" style="-fx-background-color: rgba(22,22,22,0.9);                                                   -fx-text-fill: white;                                                   -fx-prompt-text-fill: #aaa;                                                   -fx-border-color: #808080;                                                   -fx-border-width: 1;                                                   -fx-font-size: 16;                                                   -fx-padding: 10 14 10 14;" />
                                <Button fx:id="faqGetStartedButton" onAction="#handleFaqGetStarted" prefHeight="60" prefWidth="200" style="-fx-background-color: #e50914; -fx-background-radius: 4;" text="Get Started ›" textFill="WHITE">
                                    <font><Font name="System Bold" size="22.0" /></font>
                                    <cursor><Cursor fx:constant="HAND" /></cursor>
                                </Button>
                            </HBox>
                        </VBox>
                    </VBox>

                    <!-- ===== FOOTER ===== -->
                    <VBox spacing="30" style="-fx-background-color: black; -fx-padding: 60 200 40 200;">
                        <Label text="Questions? Call 0800-100-0990" textFill="#808080">
                            <font><Font size="16.0" /></font>
                        </Label>

                        <!-- Footer Links Grid -->
                        <HBox prefWidth="880" spacing="0">
                            <!-- Column 1 -->
                            <VBox prefWidth="220" spacing="14">
                                <Label style="-fx-cursor: hand; -fx-underline: true;" text="FAQ" textFill="#808080">
                                    <font><Font size="13.0" /></font>
                                </Label>
                                <Label style="-fx-cursor: hand; -fx-underline: true;" text="Investor Relations" textFill="#808080">
                                    <font><Font size="13.0" /></font>
                                </Label>
                                <Label style="-fx-cursor: hand; -fx-underline: true;" text="Privacy" textFill="#808080">
                                    <font><Font size="13.0" /></font>
                                </Label>
                                <Label style="-fx-cursor: hand; -fx-underline: true;" text="Speed Test" textFill="#808080">
                                    <font><Font size="13.0" /></font>
                                </Label>
                            </VBox>
                            <!-- Column 2 -->
                            <VBox prefWidth="220" spacing="14">
                                <Label style="-fx-cursor: hand; -fx-underline: true;" text="Help Centre" textFill="#808080">
                                    <font><Font size="13.0" /></font>
                                </Label>
                                <Label style="-fx-cursor: hand; -fx-underline: true;" text="Jobs" textFill="#808080">
                                    <font><Font size="13.0" /></font>
                                </Label>
                                <Label style="-fx-cursor: hand; -fx-underline: true;" text="Cookie Preferences" textFill="#808080">
                                    <font><Font size="13.0" /></font>
                                </Label>
                                <Label style="-fx-cursor: hand; -fx-underline: true;" text="Corporate Information" textFill="#808080">
                                    <font><Font size="13.0" /></font>
                                </Label>
                            </VBox>
                            <!-- Column 3 -->
                            <VBox prefWidth="220" spacing="14">
                                <Label style="-fx-cursor: hand; -fx-underline: true;" text="Account" textFill="#808080">
                                    <font><Font size="13.0" /></font>
                                </Label>
                                <Label style="-fx-cursor: hand; -fx-underline: true;" text="Ways to Watch" textFill="#808080">
                                    <font><Font size="13.0" /></font>
                                </Label>
                                <Label style="-fx-cursor: hand; -fx-underline: true;" text="Terms of Use" textFill="#808080">
                                    <font><Font size="13.0" /></font>
                                </Label>
                                <Label style="-fx-cursor: hand; -fx-underline: true;" text="Contact Us" textFill="#808080">
                                    <font><Font size="13.0" /></font>
                                </Label>
                            </VBox>
                            <!-- Column 4 -->
                            <VBox prefWidth="220" spacing="14">
                                <Label style="-fx-cursor: hand; -fx-underline: true;" text="Media Centre" textFill="#808080">
                                    <font><Font size="13.0" /></font>
                                </Label>
                                <Label style="-fx-cursor: hand; -fx-underline: true;" text="Terms of Use" textFill="#808080">
                                    <font><Font size="13.0" /></font>
                                </Label>
                                <Label style="-fx-cursor: hand; -fx-underline: true;" text="Legal Notices" textFill="#808080">
                                    <font><Font size="13.0" /></font>
                                </Label>
                            </VBox>
                        </HBox>

                        <!-- Language selector -->
                        <Button prefHeight="35" prefWidth="130" style="-fx-background-color: transparent; -fx-border-color: #808080; -fx-border-width: 1; -fx-border-radius: 3;" text="🌐  English ▾" textFill="#808080">
                            <font><Font size="13.0" /></font>
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                        </Button>

                        <Label text="RAKCHANET Tunisia" textFill="#808080">
                            <font><Font size="13.0" /></font>
                        </Label>
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
