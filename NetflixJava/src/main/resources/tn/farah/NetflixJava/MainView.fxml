<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="900.0" prefWidth="1280.0" style="-fx-background-color: black;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.farah.NetflixJava.Controller.MainViewController">

    <!-- ===== MainViewController ===== -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="68.0" style="-fx-background-color: rgba(0,0,0,0.9); -fx-padding: 0 40 0 40;">
            <!-- Logo -->
            <Label text="RAKCHANET" textFill="#e50914">
                <font><Font name="System Bold" size="32.0" /></font>
            </Label>
            <!-- Liens de navigation -->
            <HBox alignment="CENTER_LEFT" spacing="18" style="-fx-padding: 0 0 0 30;" />
            <Region HBox.hgrow="ALWAYS" />
            <!-- Actions côté droit -->
            <HBox alignment="CENTER" spacing="20">
                <Button fx:id="signInButton" mnemonicParsing="false" onAction="#handleSignIn" prefHeight="35" prefWidth="141.0" style="-fx-background-color: #e50914; -fx-background-radius: 4;" text="S'inscrire" textFill="WHITE">
                    <font><Font name="System Bold" size="14.0" /></font>
                    <cursor><Cursor fx:constant="HAND" /></cursor>
                </Button>
            </HBox>
        </HBox>
    </top>

    <!-- ===== CONTENU PRINCIPAL SCROLLABLE ===== -->
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background: black; -fx-background-color: black; -fx-border-color: black;" vbarPolicy="AS_NEEDED" BorderPane.alignment="CENTER">
            <content>
                <VBox style="-fx-background-color: black;">

                    <!-- ===== SECTION HÉRO AVEC BACKGROUND IMAGE STYLE NETFLIX ===== -->
                    <StackPane prefHeight="680.0" prefWidth="1280.0">

                        <!-- Couche 1 : Background image via CSS style inline (dégradé cinématique Netflix) -->
                        <Region style="-fx-background-image: url('@/ImagesNet\images.jpeg'); -fx-background-size: cover; -fx-background-position: center center; -fx-background-repeat: no-repeat;" />

                        <!-- Couche 2 : Superposition dégradé sombre style Netflix (haut + bas + global) -->
                        <Region style="-fx-background-color: linear-gradient(                                            from 0% 0% to 0% 100%,                                            rgba(0,0,0,0.6) 0%,                                            rgba(0,0,0,0.1) 40%,                                            rgba(0,0,0,0.1) 60%,                                            rgba(0,0,0,0.8) 100%                                        );" />

                        <!-- Couche 3 : Contenu texte par-dessus -->
                        <VBox alignment="CENTER" spacing="24" style="-fx-padding: 80 100 80 100;" styleClass="hero-section" stylesheets="@mainView.css">
                            <Label alignment="CENTER" text="Films, séries télévisées et bien plus encore" textFill="WHITE" wrapText="true">
                                <font><Font name="System Bold" size="52.0" /></font>
                            </Label>
                            <Label alignment="CENTER" text="Regardez où vous voulez. Annulez à tout moment." textFill="WHITE">
                                <font><Font size="26.0" /></font>
                            </Label>
                            <Label alignment="CENTER" text="Prêt à regarder ? Saisissez votre adresse e-mail pour créer ou réactiver votre abonnement." textFill="WHITE" wrapText="true">
                                <font><Font size="19.0" /></font>
                            </Label>
                            <HBox alignment="CENTER" spacing="10">
                                <TextField fx:id="heroEmailField" prefHeight="60" prefWidth="430" promptText="Adresse e-mail" style="-fx-background-color: rgba(22,22,22,0.9);                                                   -fx-text-fill: white;                                                   -fx-prompt-text-fill: #aaa;                                                   -fx-border-color: #808080;                                                   -fx-border-width: 1;                                                   -fx-font-size: 16;                                                   -fx-padding: 10 14 10 14;" />
                                <Button fx:id="heroGetStartedButton" onAction="#handleHeroGetStarted" prefHeight="60" prefWidth="200" style="-fx-background-color: #e50914; -fx-background-radius: 4; -fx-font-size: 22;" text="Commencer ›" textFill="WHITE">
                                    <font><Font name="System Bold" size="22.0" /></font>
                                    <cursor><Cursor fx:constant="HAND" /></cursor>
                                </Button>
                            </HBox>
                        </VBox>
                    </StackPane>

                    <!-- ===== FONCTIONNALITÉ 1 : REGARDER SUR LA TV ===== -->
                    <HBox alignment="CENTER" prefHeight="500" prefWidth="1280" spacing="40" style="-fx-background-color: black; -fx-border-color: #222; -fx-border-width: 0 0 8 0; -fx-padding: 60 80 60 80;">
                        <VBox alignment="CENTER_LEFT" prefWidth="560" spacing="24">
                            <Label text="Profitez sur votre TV." textFill="WHITE" wrapText="true">
                                <font><Font name="System Bold" size="50.0" /></font>
                            </Label>
                            <Label text="Regardez sur les Smart TV, PlayStation, Xbox, Chromecast, Apple TV, lecteurs Blu-ray et bien plus encore." textFill="WHITE" wrapText="true">
                                <font><Font size="22.0" /></font>
                            </Label>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <!-- Emplacement image TV -->
                        <StackPane prefHeight="380" prefWidth="500" style="-fx-background-color: #1a1a2e; -fx-background-radius: 8;">
                            <Label style="-fx-font-size: 120; -fx-opacity: 0.6;" text="📺" />
                        </StackPane>
                    </HBox>

                    <!-- ===== FONCTIONNALITÉ 2 : TÉLÉCHARGEMENT ===== -->
                    <HBox alignment="CENTER" prefHeight="500" prefWidth="1280" spacing="40" style="-fx-background-color: black; -fx-border-color: #222; -fx-border-width: 0 0 8 0; -fx-padding: 60 80 60 80;">
                        <!-- Emplacement image téléchargement -->
                        <StackPane prefHeight="380" prefWidth="500" style="-fx-background-color: #1a1a2e; -fx-background-radius: 8;">
                            <Label style="-fx-font-size: 120; -fx-opacity: 0.6;" text="📱" />
                        </StackPane>
                        <Region HBox.hgrow="ALWAYS" />
                        <VBox alignment="CENTER_LEFT" prefWidth="560" spacing="24">
                            <Label text="Téléchargez vos séries pour regarder hors ligne." textFill="WHITE" wrapText="true">
                                <font><Font name="System Bold" size="50.0" /></font>
                            </Label>
                            <Label text="Enregistrez facilement vos favoris et ayez toujours quelque chose à regarder." textFill="WHITE" wrapText="true">
                                <font><Font size="22.0" /></font>
                            </Label>
                            <!-- Carte animation téléchargement -->
                            <HBox alignment="CENTER_LEFT" spacing="14" style="-fx-background-color: black;                                          -fx-border-color: #e50914;                                          -fx-border-width: 2;                                          -fx-border-radius: 12;                                          -fx-background-radius: 12;                                          -fx-padding: 12 20 12 16;">
                                <Label style="-fx-font-size: 42;" text="🎬" />
                                <VBox spacing="3">
                                    <Label text="Stranger Things" textFill="WHITE">
                                        <font><Font name="System Bold" size="15.0" /></font>
                                    </Label>
                                    <Label text="Téléchargement en cours..." textFill="#0071eb">
                                        <font><Font size="13.0" /></font>
                                    </Label>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS" />
                                <Label style="-fx-font-size: 26;" text="⬇" textFill="#e50914" />
                            </HBox>
                        </VBox>
                    </HBox>

                    <!-- ===== FONCTIONNALITÉ 3 : REGARDER PARTOUT ===== -->
                    <HBox alignment="CENTER" prefHeight="500" prefWidth="1280" spacing="40" style="-fx-background-color: black; -fx-border-color: #222; -fx-border-width: 0 0 8 0; -fx-padding: 60 80 60 80;">
                        <VBox alignment="CENTER_LEFT" prefWidth="560" spacing="24">
                            <Label text="Regardez partout." textFill="WHITE" wrapText="true">
                                <font><Font name="System Bold" size="50.0" /></font>
                            </Label>
                            <Label text="Diffusez des films et séries illimités sur votre téléphone, tablette, ordinateur portable et télévision." textFill="WHITE" wrapText="true">
                                <font><Font size="22.0" /></font>
                            </Label>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <!-- Illustration appareils -->
                        <StackPane prefHeight="380" prefWidth="500" style="-fx-background-color: #0d1117; -fx-background-radius: 8;">
                            <HBox alignment="CENTER" spacing="10">
                                <Label style="-fx-font-size: 80; -fx-opacity: 0.7;" text="💻" />
                                <Label style="-fx-font-size: 60; -fx-opacity: 0.7;" text="📱" />
                                <Label style="-fx-font-size: 90; -fx-opacity: 0.7;" text="🖥" />
                            </HBox>
                        </StackPane>
                    </HBox>

                    <!-- ===== FONCTIONNALITÉ 4 : ENFANTS ===== -->
                    <HBox alignment="CENTER" prefHeight="500" prefWidth="1280" spacing="40" style="-fx-background-color: black; -fx-border-color: #222; -fx-border-width: 0 0 8 0; -fx-padding: 60 80 60 80;">
                        <!-- Emplacement image enfants -->
                        <StackPane prefHeight="380" prefWidth="500" style="-fx-background-color: #1a0030; -fx-background-radius: 8;">
                            <Label style="-fx-font-size: 100; -fx-opacity: 0.7;" text="👶🎈" />
                        </StackPane>
                        <Region HBox.hgrow="ALWAYS" />
                        <VBox alignment="CENTER_LEFT" prefWidth="560" spacing="24">
                            <Label text="Créez des profils pour les enfants." textFill="WHITE" wrapText="true">
                                <font><Font name="System Bold" size="50.0" /></font>
                            </Label>
                            <Label text="Emmenez les enfants en aventure avec leurs personnages préférés dans un espace conçu juste pour eux — inclus dans votre abonnement." textFill="WHITE" wrapText="true">
                                <font><Font size="22.0" /></font>
                            </Label>
                        </VBox>
                    </HBox>

                    <!-- ===== SECTION FAQ ===== -->
                    <VBox spacing="0" style="-fx-background-color: black; -fx-border-color: #222; -fx-border-width: 0 0 8 0; -fx-padding: 70 200 70 200;">
                        <Label text="Questions fréquemment posées" textFill="WHITE">
                            <font><Font name="System Bold" size="50.0" /></font>
                            <VBox.margin><Insets bottom="20" /></VBox.margin>
                        </Label>

                        <!-- FAQ 1 -->
                        <TitledPane animated="false" expanded="false" style="-fx-background-color: #303030; -fx-text-fill: white; -fx-border-color: #555; -fx-border-width: 0 0 2 0;" stylesheets="@Style.css" text="Qu'est-ce que RAKCHANET ?">
                            <font><Font name="System Bold" size="22.0" /></font>
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                            <content>
                                <AnchorPane style="-fx-background-color: #303030; -fx-padding: 30 25 30 25;">
                                    <Label text="RAKCHANET est un service de streaming qui propose une large variété de séries télévisées primées, de films, d'anime, de documentaires et bien plus encore sur des milliers d'appareils connectés à Internet.&#10;&#10;Vous pouvez regarder autant que vous le souhaitez, quand vous le souhaitez, sans aucune publicité — le tout pour un prix mensuel abordable. Il y a toujours quelque chose de nouveau à découvrir et de nouvelles séries et films sont ajoutés chaque semaine !" textFill="WHITE" wrapText="true" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
                                        <font><Font size="22.0" /></font>
                                    </Label>
                                </AnchorPane>
                            </content>
                        </TitledPane>
                        <Region prefHeight="3" />

                        <!-- FAQ 2 -->
                        <TitledPane animated="false" expanded="false" style="-fx-background-color: #303030; -fx-text-fill: white; -fx-border-color: #555; -fx-border-width: 0 0 2 0;" stylesheets="@Style.css" text="Combien coûte RAKCHANET ?">
                            <font><Font name="System Bold" size="22.0" /></font>
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                            <content>
                                <AnchorPane style="-fx-background-color: #303030; -fx-padding: 30 25 30 25;">
                                    <Label text="Regardez RAKCHANET sur votre smartphone, tablette, Smart TV, ordinateur portable ou appareil de streaming, le tout pour un abonnement mensuel fixe. Les forfaits vont de 4,99 € à 17,99 € par mois. Aucun frais supplémentaire, aucun engagement." textFill="WHITE" wrapText="true" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
                                        <font><Font size="22.0" /></font>
                                    </Label>
                                </AnchorPane>
                            </content>
                        </TitledPane>
                        <Region prefHeight="3" />

                        <!-- FAQ 3 -->
                        <TitledPane animated="false" expanded="false" style="-fx-background-color: #303030; -fx-text-fill: white; -fx-border-color: #555; -fx-border-width: 0 0 2 0;" stylesheets="@Style.css" text="Où puis-je regarder ?">
                            <font><Font name="System Bold" size="22.0" /></font>
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                            <content>
                                <AnchorPane style="-fx-background-color: #303030; -fx-padding: 30 25 30 25;">
                                    <Label text="Regardez où vous voulez, quand vous voulez. Connectez-vous avec votre compte RAKCHANET pour regarder instantanément sur le web depuis rakchanet.com ou sur n'importe quel appareil connecté à Internet disposant de l'application RAKCHANET, y compris les Smart TV, smartphones, tablettes, lecteurs multimédias et consoles de jeux.&#10;&#10;Vous pouvez également télécharger vos séries préférées avec l'application iOS, Android ou Windows 10." textFill="WHITE" wrapText="true" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
                                        <font><Font size="22.0" /></font>
                                    </Label>
                                </AnchorPane>
                            </content>
                        </TitledPane>
                        <Region prefHeight="3" />

                        <!-- FAQ 4 -->
                        <TitledPane animated="false" expanded="false" style="-fx-background-color: #303030; -fx-text-fill: white; -fx-border-color: #555; -fx-border-width: 0 0 2 0;" stylesheets="@Style.css" text="Comment résilier mon abonnement ?">
                            <font><Font name="System Bold" size="22.0" /></font>
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                            <content>
                                <AnchorPane style="-fx-background-color: #303030; -fx-padding: 30 25 30 25;">
                                    <Label text="RAKCHANET est flexible. Pas de contrats contraignants, pas d'engagements. Vous pouvez facilement résilier votre compte en ligne en deux clics. Aucuns frais de résiliation — commencez ou arrêtez votre abonnement à tout moment." textFill="WHITE" wrapText="true" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
                                        <font><Font size="22.0" /></font>
                                    </Label>
                                </AnchorPane>
                            </content>
                        </TitledPane>
                        <Region prefHeight="3" />

                        <!-- FAQ 5 -->
                        <TitledPane animated="false" expanded="false" style="-fx-background-color: #303030; -fx-text-fill: white; -fx-border-color: #555; -fx-border-width: 0 0 2 0;" stylesheets="@Style.css" text="Que puis-je regarder sur RAKCHANET ?">
                            <font><Font name="System Bold" size="22.0" /></font>
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                            <content>
                                <AnchorPane style="-fx-background-color: #303030; -fx-padding: 30 25 30 25;">
                                    <Label text="RAKCHANET possède une vaste bibliothèque de longs métrages, documentaires, séries télévisées, anime, productions originales RAKCHANET primées et bien plus encore. Regardez autant que vous le souhaitez, quand vous le souhaitez." textFill="WHITE" wrapText="true" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
                                        <font><Font size="22.0" /></font>
                                    </Label>
                                </AnchorPane>
                            </content>
                        </TitledPane>
                        <Region prefHeight="3" />

                        <!-- FAQ 6 -->
                        <TitledPane animated="false" expanded="false" style="-fx-background-color: #303030; -fx-text-fill: white; -fx-border-color: #555; -fx-border-width: 0 0 2 0;" stylesheets="@Style.css" text="RAKCHANET est-il adapté aux enfants ?">
                            <font><Font name="System Bold" size="22.0" /></font>
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                            <content>
                                <AnchorPane style="-fx-background-color: #303030; -fx-padding: 30 25 30 25;">
                                    <Label text="L'expérience RAKCHANET Enfants est incluse dans votre abonnement pour donner aux parents le contrôle, tandis que les enfants profitent de séries et films adaptés à la famille dans leur propre espace.&#10;&#10;Les profils enfants sont dotés de contrôles parentaux protégés par un code PIN qui permettent de restreindre le niveau de maturité des contenus que les enfants peuvent regarder et de bloquer des titres spécifiques que vous ne souhaitez pas qu'ils voient." textFill="WHITE" wrapText="true" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
                                        <font><Font size="22.0" /></font>
                                    </Label>
                                </AnchorPane>
                            </content>
                        </TitledPane>

                        <!-- CTA sous la FAQ -->
                        <VBox alignment="CENTER" spacing="16" style="-fx-padding: 50 0 10 0;">
                            <Label alignment="CENTER" text="Prêt à regarder ? Saisissez votre adresse e-mail pour créer ou réactiver votre abonnement." textFill="WHITE" wrapText="true">
                                <font><Font size="19.0" /></font>
                            </Label>
                            <HBox alignment="CENTER" spacing="10">
                                <TextField fx:id="faqEmailField" prefHeight="60" prefWidth="430" promptText="Adresse e-mail" style="-fx-background-color: rgba(22,22,22,0.9);                                                   -fx-text-fill: white;                                                   -fx-prompt-text-fill: #aaa;                                                   -fx-border-color: #808080;                                                   -fx-border-width: 1;                                                   -fx-font-size: 16;                                                   -fx-padding: 10 14 10 14;" />
                                <Button fx:id="faqGetStartedButton" onAction="#handleFaqGetStarted" prefHeight="60" prefWidth="200" style="-fx-background-color: #e50914; -fx-background-radius: 4;" text="Commencer ›" textFill="WHITE">
                                    <font><Font name="System Bold" size="22.0" /></font>
                                    <cursor><Cursor fx:constant="HAND" /></cursor>
                                </Button>
                            </HBox>
                        </VBox>
                    </VBox>

                    <!-- ===== PIED DE PAGE ===== -->
                    <VBox spacing="30" style="-fx-background-color: black; -fx-padding: 60 200 40 200;">
                        <Label text="Des questions ? Appelez le 0800-100-0990" textFill="#808080">
                            <font><Font size="16.0" /></font>
                        </Label>

                        <!-- Grille de liens du pied de page -->
                        <HBox prefWidth="880" spacing="0">
                            <!-- Colonne 1 -->
                            <VBox prefWidth="220" spacing="14">
                                <Label style="-fx-cursor: hand; -fx-underline: true;" text="FAQ" textFill="#808080">
                                    <font><Font size="13.0" /></font>
                                </Label>
                                <Label style="-fx-cursor: hand; -fx-underline: true;" text="Relations investisseurs" textFill="#808080">
                                    <font><Font size="13.0" /></font>
                                </Label>
                                <Label style="-fx-cursor: hand; -fx-underline: true;" text="Confidentialité" textFill="#808080">
                                    <font><Font size="13.0" /></font>
                                </Label>
                                <Label style="-fx-cursor: hand; -fx-underline: true;" text="Test de vitesse" textFill="#808080">
                                    <font><Font size="13.0" /></font>
                                </Label>
                            </VBox>
                            <!-- Colonne 2 -->
                            <VBox prefWidth="220" spacing="14">
                                <Label style="-fx-cursor: hand; -fx-underline: true;" text="Centre d'aide" textFill="#808080">
                                    <font><Font size="13.0" /></font>
                                </Label>
                                <Label style="-fx-cursor: hand; -fx-underline: true;" text="Emplois" textFill="#808080">
                                    <font><Font size="13.0" /></font>
                                </Label>
                                <Label style="-fx-cursor: hand; -fx-underline: true;" text="Préférences cookies" textFill="#808080">
                                    <font><Font size="13.0" /></font>
                                </Label>
                                <Label style="-fx-cursor: hand; -fx-underline: true;" text="Informations légales" textFill="#808080">
                                    <font><Font size="13.0" /></font>
                                </Label>
                            </VBox>
                            <!-- Colonne 3 -->
                            <VBox prefWidth="220" spacing="14">
                                <Label style="-fx-cursor: hand; -fx-underline: true;" text="Mon compte" textFill="#808080">
                                    <font><Font size="13.0" /></font>
                                </Label>
                                <Label style="-fx-cursor: hand; -fx-underline: true;" text="Façons de regarder" textFill="#808080">
                                    <font><Font size="13.0" /></font>
                                </Label>
                                <Label style="-fx-cursor: hand; -fx-underline: true;" text="Conditions d'utilisation" textFill="#808080">
                                    <font><Font size="13.0" /></font>
                                </Label>
                                <Label style="-fx-cursor: hand; -fx-underline: true;" text="Contactez-nous" textFill="#808080">
                                    <font><Font size="13.0" /></font>
                                </Label>
                            </VBox>
                            <!-- Colonne 4 -->
                            <VBox prefWidth="220" spacing="14">
                                <Label style="-fx-cursor: hand; -fx-underline: true;" text="Espace presse" textFill="#808080">
                                    <font><Font size="13.0" /></font>
                                </Label>
                                <Label style="-fx-cursor: hand; -fx-underline: true;" text="Conditions d'utilisation" textFill="#808080">
                                    <font><Font size="13.0" /></font>
                                </Label>
                                <Label style="-fx-cursor: hand; -fx-underline: true;" text="Mentions légales" textFill="#808080">
                                    <font><Font size="13.0" /></font>
                                </Label>
                            </VBox>
                        </HBox>

                        <!-- Sélecteur de langue -->
                        <Button prefHeight="35" prefWidth="130" style="-fx-background-color: transparent; -fx-border-color: #808080; -fx-border-width: 1; -fx-border-radius: 3;" text="🌐  Français ▾" textFill="#808080">
                            <font><Font size="13.0" /></font>
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                        </Button>

                        <Label text="RAKCHANET Tunisie" textFill="#808080">
                            <font><Font size="13.0" /></font>
                        </Label>
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
