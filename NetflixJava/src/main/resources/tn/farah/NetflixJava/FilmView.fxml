<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="900" prefWidth="1100" style="-fx-background-color: #141414;" stylesheets="@home.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.farah.NetflixJava.Controller.FilmViewController">

    <!-- ===================================================== -->
    <!-- NAVBAR                                                  -->
    <!-- ===================================================== -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="30" style="-fx-background-color: #141414; -fx-padding: 15 30 15 30;">

            <Label style="-fx-text-fill: #E50914; -fx-font-size: 28px; -fx-font-weight: bold;" text="RAKCHANET" />

            <HBox spacing="20">
                <Button fx:id="AcceuilBtn" mnemonicParsing="false" onAction="#handleAcceuil" style="-fx-background-color: transparent;" text="Accueil" textFill="#faf6f6">
                    <font><Font name="System Bold" size="13.0" /></font>
                    <cursor><Cursor fx:constant="HAND" /></cursor>
                </Button>
                <Button mnemonicParsing="false" onAction="#handleFilm" style="-fx-background-color: transparent;" text="Films" textFill="#faf6f6">
                    <cursor><Cursor fx:constant="HAND" /></cursor>
                </Button>
                <Button mnemonicParsing="false" onAction="#handleSeries" style="-fx-background-color: transparent;" text="Séries" textFill="#faf6f6">
                    <cursor><Cursor fx:constant="HAND" /></cursor>
                </Button>
                <Button mnemonicParsing="false" onAction="#handleMyList" style="-fx-background-color: transparent;" text="Ma Liste" textFill="#faf6f6">
                    <cursor><Cursor fx:constant="HAND" /></cursor>
                </Button>
            </HBox>

            <HBox HBox.hgrow="ALWAYS" />

            <!-- PROFIL -->
            <HBox fx:id="profilBox" alignment="CENTER" onMouseClicked="#onProfilClicked" spacing="10" style="-fx-cursor: hand; -fx-padding: 4 10 4 10;                          -fx-background-color: #1f1f1f; -fx-background-radius: 8;">
                <Label fx:id="labelUserName" style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;" text="Utilisateur" />
                <StackPane fx:id="avatarContainer" prefHeight="38" prefWidth="38">
                    <ImageView fx:id="avatarImage" fitHeight="38" fitWidth="38" preserveRatio="false" smooth="true">
                        <clip>
                            <Rectangle arcHeight="8" arcWidth="8" height="38" width="38" />
                        </clip>
                    </ImageView>
                    <ImageView fitHeight="37.0" fitWidth="47.0" pickOnBounds="true" preserveRatio="true">
                        <image><Image url="@ImagesNet/log5.jpg" /></image>
                    </ImageView>
                </StackPane>
            </HBox>

        </HBox>
    </top>

    <!-- ===================================================== -->
    <!-- CONTENU PRINCIPAL                                       -->
    <!-- ===================================================== -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: #141414; -fx-background-color: #141414;                            -fx-border-color: transparent;">
            <content>
                <VBox spacing="0">

                    <!-- ============================================= -->
                    <!-- POSTER DU FILM                                 -->
                    <!-- ============================================= -->
                    <StackPane fx:id="videoPane" prefHeight="520" style="-fx-background-color: #000000;">

                        <ImageView fx:id="posterImage" fitHeight="520" fitWidth="1100" opacity="0.55" preserveRatio="false" smooth="true" />

                        <Pane mouseTransparent="true" style="-fx-background-color: linear-gradient(to bottom, transparent 30%, #141414 100%);" />

                        <VBox alignment="BOTTOM_LEFT" spacing="16" style="-fx-padding: 0 0 48 48;" StackPane.alignment="BOTTOM_LEFT">

                            <Label fx:id="filmTitleVideo" maxWidth="700" style="-fx-text-fill: white; -fx-font-size: 38px; -fx-font-weight: bold;                                           -fx-effect: dropshadow(gaussian, black, 10, 0.6, 0, 2);" text="Titre du film" wrapText="true" />

                            <Label fx:id="categories" style="-fx-text-fill: #aaaaaa; -fx-font-size: 13px;" text="" />

                            <Label fx:id="posterDesc" maxWidth="600" style="-fx-text-fill: #cccccc; -fx-font-size: 14px;                                           -fx-effect: dropshadow(gaussian, black, 6, 0.5, 0, 1);" text="" wrapText="true" />

                            <HBox spacing="14" style="-fx-padding: 8 0 0 0;">
                                <Button fx:id="btnLire" onAction="#onLire" style="-fx-background-color: white; -fx-text-fill: black;                                                -fx-font-weight: bold; -fx-font-size: 15px;                                                -fx-padding: 11 28 11 28; -fx-background-radius: 4;                                                -fx-cursor: hand;" text="▶  Lire" />
                                <Button fx:id="btnFavoris" onAction="#onFavoris" style="-fx-background-color: rgba(60,60,60,0.85); -fx-text-fill: white;                                                -fx-font-weight: bold; -fx-font-size: 15px;                                                -fx-padding: 11 28 11 28; -fx-background-radius: 4;                                                -fx-cursor: hand; -fx-border-color: white;                                                -fx-border-width: 1; -fx-border-radius: 4;" text="＋  Ajouter aux favoris" />
                        <Button fx:id="btnNoter" 
    mnemonicParsing="false" 
    onAction="#onNoter" 
    style="-fx-background-color: Red; -fx-text-fill: white; -fx-font-weight: bold; 
           -fx-font-size: 15px; -fx-padding: 11 28 11 28; -fx-background-radius: 4; 
           -fx-cursor: hand; -fx-border-color: white; -fx-border-width: 1; 
           -fx-border-radius: 4;" 
    text="Noter" />
                            </HBox>

                        </VBox>
                    </StackPane>

                    <!-- ============================================= -->
                    <!-- INFOS FILM + DISTRIBUTION                      -->
                    <!-- ============================================= -->
                    <HBox spacing="30" style="-fx-padding: 24 30 10 30;">

                        <VBox spacing="10" HBox.hgrow="ALWAYS">

                            <!-- Titre du film -->
                            <Label fx:id="filmTitle" style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;" text="Titre du film" />

                            <!-- Méta : durée + année -->
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <Label style="-fx-text-fill: #555555;" text="|" />
                                <Label fx:id="labelDuree" style="-fx-text-fill: #aaaaaa; -fx-font-size: 13px;" text="120 min" />
                                <Label style="-fx-text-fill: #555555;" text="|" />
                                <Label fx:id="labelDateSortie" style="-fx-text-fill: #aaaaaa; -fx-font-size: 13px;" text="" />
                            </HBox>

                            <!-- Synopsis court -->
                            <Label fx:id="filmDesc" maxWidth="620" style="-fx-text-fill: #cccccc; -fx-font-size: 14px;" text="" wrapText="true" />

                            <!-- Boutons d'actions -->
                            <HBox spacing="12" style="-fx-padding: 8 0 0 0;">
                                <Button fx:id="btnLike" onAction="#onLike" style="-fx-background-color: #333333; -fx-text-fill: white;                                                -fx-padding: 8 18 8 18; -fx-background-radius: 4;                                                -fx-cursor: hand; -fx-font-size: 13px;" text="J'aime" />
                                <Button fx:id="btnDislike" onAction="#onDislike" style="-fx-background-color: #333333; -fx-text-fill: white;                                                -fx-padding: 8 18 8 18; -fx-background-radius: 4;                                                -fx-cursor: hand; -fx-font-size: 13px;" text="Je n'aime pas" />
                                <Button fx:id="btnShare" onAction="#onShare" style="-fx-background-color: #333333; -fx-text-fill: white;                                                -fx-padding: 8 18 8 18; -fx-background-radius: 4;                                                -fx-cursor: hand; -fx-font-size: 13px;" text="Partager" />
                                <Button fx:id="btnDownload" onAction="#onDownload" style="-fx-background-color: #333333; -fx-text-fill: white;                                                -fx-padding: 8 18 8 18; -fx-background-radius: 4;                                                -fx-cursor: hand; -fx-font-size: 13px;" text="Télécharger" />
                            </HBox>
                        </VBox>

                        <!-- Distribution -->
                        <VBox prefWidth="260" spacing="10" style="-fx-background-color: #1f1f1f; -fx-padding: 16;                                      -fx-background-radius: 6;">
                            <Label style="-fx-text-fill: white; -fx-font-weight: bold;                                           -fx-font-size: 14px;" text="Distribution" />
                            <Label fx:id="castings" style="-fx-text-fill: #cccccc; -fx-font-size: 13px;" text="" wrapText="true">
                                <font><Font size="13.0" /></font>
                            </Label>
                            <Label fx:id="labelWarnings" style="-fx-text-fill: #d12f2f; -fx-font-size: 13px;" text="">
                                <font><Font size="13.0" /></font>
                            </Label>
                        </VBox>

                    </HBox>

                    <!-- ============================================= -->
                    <!-- BARRE ONGLETS  (pas d'onglet Épisodes ici)    -->
                    <!-- ============================================= -->
                    <HBox alignment="CENTER_LEFT" spacing="0" style="-fx-background-color: #141414;                                  -fx-border-color: transparent transparent #333333 transparent;                                  -fx-border-width: 0 0 1 0; -fx-padding: 10 30 0 30;">

                        <!-- À propos (actif par défaut) -->
                        <VBox fx:id="tabApropos" alignment="CENTER" onMouseClicked="#onTabApropos" style="-fx-padding: 14 20 0 20; -fx-cursor: hand;">
                            <Label style="-fx-text-fill: white; -fx-font-size: 14px;                                           -fx-font-weight: bold;" text="À propos" />
                            <HBox prefHeight="3" style="-fx-background-color: #E50914;                                          -fx-background-radius: 2 2 0 0;                                          -fx-padding: 10 0 0 0;" HBox.hgrow="ALWAYS" />
                        </VBox>

                        <!-- Bandes-annonces -->
                        <VBox fx:id="tabBandes" alignment="CENTER" onMouseClicked="#onTabBandes" style="-fx-padding: 14 20 0 20; -fx-cursor: hand;">
                            <Label style="-fx-text-fill: #aaaaaa; -fx-font-size: 14px;" text="Bandes-annonces" />
                            <HBox prefHeight="3" prefWidth="0" style="-fx-background-color: transparent; -fx-padding: 10 0 0 0;" />
                        </VBox>

                        <!-- Commentaires -->
                        <VBox fx:id="tabCommentaires" alignment="CENTER" onMouseClicked="#onTabCommentaires" style="-fx-padding: 14 20 0 20; -fx-cursor: hand;">
                            <Label style="-fx-text-fill: #aaaaaa; -fx-font-size: 14px;" text="Commentaires" />
                            <HBox prefHeight="3" prefWidth="0" style="-fx-background-color: transparent; -fx-padding: 10 0 0 0;" />
                        </VBox>

                        <!-- Similaires -->
                        <VBox fx:id="tabSimilaires" alignment="CENTER" onMouseClicked="#onTabSimilaires" style="-fx-padding: 14 20 0 20; -fx-cursor: hand;">
                            <Label style="-fx-text-fill: #aaaaaa; -fx-font-size: 14px;" text="Similaires" />
                            <HBox prefHeight="3" prefWidth="0" style="-fx-background-color: transparent; -fx-padding: 10 0 0 0;" />
                        </VBox>

                    </HBox>

                    <!-- ============================================= -->
                    <!-- ZONE CONTENU ONGLETS                          -->
                    <!-- ============================================= -->
                    <VBox spacing="0" style="-fx-padding: 20 30 30 30;">

                        <!-- ───── ONGLET À PROPOS (visible par défaut) ───── -->
                        <VBox fx:id="panelApropos" managed="true" spacing="14" visible="true">
                            <Label style="-fx-text-fill: white; -fx-font-size: 18px;                                           -fx-font-weight: bold;" text="À propos du film" />
                            <Label fx:id="labelSynopsis" style="-fx-text-fill: #cccccc; -fx-font-size: 14px;" text="" wrapText="true" />
                            <HBox spacing="30" style="-fx-padding: 10 0 0 0;">
                                <VBox spacing="6">
                                    <Label style="-fx-text-fill: #aaaaaa; -fx-font-size: 12px;" text="RÉALISATEUR" />
                                    <Label fx:id="labelProducteur" style="-fx-text-fill: white; -fx-font-size: 14px;" text="" />
                                </VBox>
                                <VBox spacing="6">
                                    <Label style="-fx-text-fill: #aaaaaa; -fx-font-size: 12px;" text="GENRE" />
                                    <Label fx:id="labelGenre" style="-fx-text-fill: white; -fx-font-size: 14px;" text="" />
                                </VBox>
                                <VBox spacing="6">
                                    <Label style="-fx-text-fill: #aaaaaa; -fx-font-size: 12px;" text="ANNÉE" />
                                    <Label fx:id="labelAnnee" style="-fx-text-fill: white; -fx-font-size: 14px;" text="" />
                                </VBox>
                            </HBox>

                            <!-- ✅ WARNINGS EN ROUGE dans À propos -->
                            <VBox spacing="6" style="-fx-padding: 10 0 0 0;">
                                <Label style="-fx-text-fill: #aaaaaa; -fx-font-size: 12px;" text="AVERTISSEMENTS" />
                                <Label fx:id="labelWarningsApropos" style="-fx-text-fill: #E50914; -fx-font-size: 13px;                                               -fx-font-weight: bold;" text="" wrapText="true" />
                            </VBox>
                        </VBox>

                        <!-- ───── ONGLET BANDES-ANNONCES ───── -->
                        <VBox fx:id="panelBandes" managed="false" spacing="14" visible="false">
                            <Label style="-fx-text-fill: white; -fx-font-size: 18px;                                           -fx-font-weight: bold;" text="Bandes-annonces" />
                            <HBox spacing="16">
                                <StackPane prefHeight="158" prefWidth="280" style="-fx-background-color: #2a2a2a;                                                   -fx-background-radius: 6; -fx-cursor: hand;">
                                    <Label style="-fx-text-fill: white; -fx-font-size: 40px;                                                   -fx-opacity: 0.5;" text="▶" />
                                    <Label style="-fx-text-fill: #aaaaaa; -fx-font-size: 13px;" text="Bande-annonce officielle" StackPane.alignment="BOTTOM_LEFT">
                                        <StackPane.margin>
                                            <Insets bottom="12" left="12" />
                                        </StackPane.margin>
                                    </Label>
                                </StackPane>
                                <StackPane prefHeight="158" prefWidth="280" style="-fx-background-color: #2a2a2a;                                                   -fx-background-radius: 6; -fx-cursor: hand;">
                                    <Label style="-fx-text-fill: white; -fx-font-size: 40px;                                                   -fx-opacity: 0.5;" text="▶" />
                                    <Label style="-fx-text-fill: #aaaaaa; -fx-font-size: 13px;" text="Teaser" StackPane.alignment="BOTTOM_LEFT">
                                        <StackPane.margin>
                                            <Insets bottom="12" left="12" />
                                        </StackPane.margin>
                                    </Label>
                                </StackPane>
                            </HBox>
                        </VBox>

                        <!-- ───── ONGLET COMMENTAIRES (construit en Java) ───── -->
                        <VBox fx:id="panelCommentaires" managed="false" spacing="0" visible="false" />

                        <!-- ───── ONGLET SIMILAIRES (construit en Java) ───── -->
                        <VBox fx:id="panelSimilaires" managed="false" spacing="14" visible="false" />

                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>

