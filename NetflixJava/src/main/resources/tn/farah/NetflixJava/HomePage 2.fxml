<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<!--
    J-STREAM — HomePage.fxml
    ─────────────────────────────────────────────────────────────
    Vue pure : AUCUNE donnée hardcodée ici.
    Toutes les cartes films/séries sont générées dynamiquement
    par HomeController.java à partir de la base de données.

    fx:id exposés au Controller :
      • heroTitle, heroGenreBadge, heroType, heroRating,
        heroDuration, heroYear, heroCertif, heroSynopsis
        → remplir la section hero avec le contenu "à la une"

      • carouselContainer
        → VBox dans laquelle le Controller injecte les blocs
          carousel (un par catégorie retournée par la BDD)

      • searchField
        → champ de recherche
-->

<BorderPane style="-fx-background-color: black;" styleClass="root-pane" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.farah.NetflixJava.Controller.HomeController">

    <!-- ══════════════════════════════════════════════════════ -->
    <!--                   BARRE DE NAVIGATION                 -->
    <!-- ══════════════════════════════════════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="0" styleClass="navbar">

            <Label styleClass="nav-logo" text="J-STREAM" textFill="#c12121">
            <font>
               <Font name="System Bold" size="12.0" />
            </font></Label>

            <HBox alignment="CENTER_LEFT" spacing="6" styleClass="nav-links">
                <HBox.margin><Insets left="40" /></HBox.margin>
                <Button onAction="#onMyList" style="-fx-background-color: transparent;" styleClass="nav-btn" text="Ma Liste" textFill="#fcfafa" />
                <Button onAction="#onMovies" style="-fx-background-color: transparent;" styleClass="nav-btn" text="Films" textFill="#efebeb">
               <cursor>
                  <Cursor fx:constant="HAND" />
               </cursor></Button>
                <Button onAction="#onSeries" style="-fx-background-color: TRANSPARENT;" styleClass="nav-btn" text="Séries" textFill="#f7f1f1" />
            </HBox>

              <Pane mouseTransparent="true" styleClass="fade-overlay-bottom" />

            <Region style="-fx-background-color: black;" HBox.hgrow="ALWAYS" />

            <HBox alignment="CENTER" spacing="6" styleClass="search-container">
                <TextField fx:id="searchField" onKeyReleased="#onSearch" prefWidth="240" promptText="Titres, genres, années..." style="-fx-background-color: TRANSPARENT;" styleClass="search-field" />
                <Button onAction="#onSearchBtn" style="-fx-background-color: TRANSPARENT;" styleClass="search-icon-btn" text="🔍" textFill="#f7f3f3">
               <cursor>
                  <Cursor fx:constant="HAND" />
               </cursor></Button>
            </HBox>

            <HBox alignment="CENTER" spacing="8" style="-fx-padding: 0 24 0 16;">
                <Label text="🔔" textFill="#f4eeee">
               <cursor>
                  <Cursor fx:constant="HAND" />
               </cursor></Label>
                <StackPane styleClass="avatar-container">
                    <Label fx:id="avatarLabel" styleClass="avatar-label" text="U" />
                </StackPane>
            </HBox>

        </HBox>
    </top>

    <!-- ══════════════════════════════════════════════════════ -->
    <!--                     CONTENU PRINCIPAL                 -->
    <!-- ══════════════════════════════════════════════════════ -->
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="main-scroll" vbarPolicy="AS_NEEDED">
            <VBox spacing="0" styleClass="content-wrapper">

                <!-- ────────────────────────────────────────── -->
                <!--   HERO — rempli par HomeController        -->
                <!--   via heroSection.setStyle() pour le bg   -->
                <!--   et les Labels fx:id pour les textes     -->
                <!-- ────────────────────────────────────────── -->
                
                <StackPane fx:id="heroSection" alignment="CENTER_LEFT" styleClass="hero-section">
 					
                    <Pane fx:id="heroBackdrop" minHeight="700.0" style="-fx-max-height: 700px;" styleClass="hero-backdrop">
                  <opaqueInsets>
                     <Insets />
                  </opaqueInsets></Pane>
   
                                         <HBox alignment="BOTTOM_LEFT" style="-fx-padding: 0 0 60px 60px;" styleClass="hero-content-overlay">
                        <VBox alignment="CENTER_LEFT" maxWidth="600" prefHeight="554.0" prefWidth="265.0" spacing="20.0" style="-fx-translate-y: 80;" styleClass="hero-text-block">
   
                                                 <HBox alignment="CENTER_LEFT" spacing="8">
                                <Label fx:id="heroType" styleClass="hero-badge-featured" text="" textFill="WHITE" />
                                <Label fx:id="heroGenreBadge" styleClass="hero-badge-genre" text="" textFill="WHITE" />
                            </HBox>
   
                                                 <Label fx:id="heroTitle" style="-fx-font-size: 50; -fx-font-weight: bold;" styleClass="hero-title" text="" textFill="WHITE" wrapText="true">
                        <font>
                           <Font size="48.0" />
                        </font>
                     </Label>
   
                                                 <HBox alignment="CENTER_LEFT" spacing="16">
                                <Label fx:id="heroRating" styleClass="hero-stars" text="" textFill="WHITE" />
                                <Label fx:id="heroDuration" styleClass="hero-meta" text="" textFill="WHITE" />
                                <Label fx:id="heroYear" styleClass="hero-meta" text="" textFill="WHITE" />
                                <Label fx:id="heroCertif" styleClass="hero-meta-badge" text="" textFill="WHITE" />
                            </HBox>
   
                                                 <Label fx:id="heroSynopsis" styleClass="hero-synopsis" text="" textFill="WHITE" wrapText="true" />
   
                                                 <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 8 0 0 0;">
                                <Button onAction="#onPlayFeatured" style="-fx-background-color: WHITE;" styleClass="btn-play-hero" text="▶  Lire">
                           <font>
                              <Font name="System Bold" size="12.0" />
                           </font>
                           <cursor>
                              <Cursor fx:constant="HAND" />
                           </cursor>
                        </Button>
                                <Button onAction="#onMoreInfoFeatured" styleClass="btn-info-hero" text="ℹ  Plus d'infos" textFill="WHITE">
                           <cursor>
                              <Cursor fx:constant="HAND" />
                           </cursor>
                           <font>
                              <Font name="System Bold" size="12.0" />
                           </font>
                        </Button>
                                <Button onAction="#onAddFeaturedToList" styleClass="btn-list-hero" text="+ Ma Liste" textFill="WHITE">
                           <font>
                              <Font name="System Bold" size="12.0" />
                           </font>
                           <cursor>
                              <Cursor fx:constant="HAND" />
                           </cursor>
                        </Button>
                            </HBox>
                     <opaqueInsets>
                        <Insets left="60.0" />
                     </opaqueInsets>
   
                                             </VBox>
                  <padding>
                     <Insets top="140.0" />
                  </padding>
                    </HBox>
               <padding>
                  <Insets left="50.0" />
               </padding>

                </StackPane>

                                                 <!-- ────────────────────────────────────────── -->
                <!--   CAROUSELS — entièrement générés par     -->
                <!--   HomeController depuis la BDD.           -->
                <!--   Un carousel par catégorie/genre,        -->
                <!--   autant de cartes que de contenus.       -->
                <!-- ────────────────────────────────────────── -->
                <VBox fx:id="carouselContainer" prefHeight="151.0" prefWidth="1044.0" spacing="36" style="-fx-padding: 0 40 60 40; -fx-translate-y: -150;" styleClass="carousels-section">
               <children>
                  <FlowPane fx:id="filmContainer" alignment="CENTER" prefHeight="96.0" prefWidth="964.0" style="-fx-background-color: transparent;" />
               </children>
            </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
