<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.media.MediaView?>
<?import javafx.scene.text.Font?>

<StackPane
 fx:id="rootPane" 
    prefHeight="450.0"
    prefWidth="800.0"
    style="-fx-background-color: black;"
    xmlns="http://javafx.com/javafx/25"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="tn.farah.NetflixJava.Controller.videoController">

   <children>

      <!-- ═══════════════════════════════════════ -->
      <!-- VIDÉO                                   -->
      <!-- ═══════════════════════════════════════ -->
      <MediaView fx:id="mediaView" />

      <!-- ═══════════════════════════════════════ -->
      <!-- OVERLAY CONTRÔLES (auto-masqué)         -->
      <!-- Visible seulement quand la souris bouge -->
      <!-- ═══════════════════════════════════════ -->
      <BorderPane
          fx:id="controlsPane"
          visible="false"
          style="-fx-background-color: rgba(0,0,0,0.0);">

         <!-- ─────────────────────────────────── -->
         <!-- HAUT : Titre de l'épisode           -->
         <!-- ─────────────────────────────────── -->
         <top>
            <HBox
                alignment="CENTER_LEFT"
                prefHeight="60.0"
                spacing="20.0"
                style="-fx-background-color: linear-gradient(to bottom, rgba(0,0,0,0.75), transparent);"
                BorderPane.alignment="CENTER">
               <children>
                  <!-- Bouton retour vers la fiche série -->
                  <Button
                      mnemonicParsing="false"
                      onAction="#handleRetour"
                      style="-fx-background-color: transparent; -fx-cursor: hand;"
                      text="← Retour"
                      textFill="WHITE">
                     <font><Font name="System Bold" size="15.0" /></font>
                  </Button>

                  <!-- Titre : "Saison X - Ép Y : Titre" -->
                  <Label fx:id="titleLabel" text="Saison n° - Ép n°" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="18.0" />
                     </font>
                  </Label>
               </children>
               <padding>
                  <Insets left="20.0" top="15.0" />
               </padding>
            </HBox>
         </top>

         <!-- ─────────────────────────────────── -->
         <!-- CENTRE : ↺  ▶/⏸  ↻               -->
         <!-- ─────────────────────────────────── -->
         <center>
            <HBox alignment="CENTER" spacing="60.0" BorderPane.alignment="CENTER">
               <children>
                  <Button
                      mnemonicParsing="false"
                      onAction="#rewind10"
                      style="-fx-background-color: transparent;"
                      text="↺ 10"
                      textFill="WHITE">
                     <font><Font size="26.0" /></font>
                  </Button>

                  <Button
                      fx:id="playButton"
                      mnemonicParsing="false"
                      onAction="#handlePlayPause"
                      style="-fx-background-color: transparent;"
                      text="▶"
                      textFill="WHITE">
                     <font><Font size="45.0" /></font>
                  </Button>

                  <Button
                      mnemonicParsing="false"
                      onAction="#forward10"
                      style="-fx-background-color: transparent;"
                      text="10 ↻"
                      textFill="WHITE">
                     <font><Font size="26.0" /></font>
                  </Button>
               </children>
            </HBox>
         </center>

         <!-- ─────────────────────────────────── -->
         <!-- BAS : Skip intro + barre + boutons  -->
         <!-- ─────────────────────────────────── -->
         <bottom>
            <VBox
                alignment="BOTTOM_CENTER"
                prefHeight="140.0"
                spacing="5.0"
                style="-fx-background-color: linear-gradient(to top, rgba(0,0,0,0.75), transparent);"
                BorderPane.alignment="CENTER">
               <children>

                  <!-- Bouton "Passer l'intro" (visible uniquement pendant l'intro) -->
                  <AnchorPane prefHeight="50.0">
                     <children>
                        <Button
                            fx:id="skipIntroButton"
                            mnemonicParsing="false"
                            onAction="#handleSkipIntro"
                            style="-fx-background-color: rgba(0,0,0,0.75);
                                   -fx-border-color: white;
                                   -fx-border-radius: 5;
                                   -fx-background-radius: 5;
                                   -fx-cursor: hand;"
                            text="⏩  Passer l'intro"
                            textFill="WHITE"
                            visible="false"
                            managed="false"
                            AnchorPane.bottomAnchor="5.0"
                            AnchorPane.rightAnchor="30.0">
                           <padding>
                              <Insets bottom="8.0" left="20.0" right="20.0" top="8.0" />
                           </padding>
                           <font>
                              <Font name="System Bold" size="13.0" />
                           </font>
                        </Button>
                     </children>
                  </AnchorPane>

                  <!-- Barre de progression + temps -->
                  <HBox alignment="CENTER" spacing="15.0">
                     <children>
                        <Slider fx:id="progressBar" HBox.hgrow="ALWAYS" />
                        <Label fx:id="timeLabel" minWidth="110.0" text="00:00 / 00:00" textFill="WHITE" />
                     </children>
                     <padding>
                        <Insets left="20.0" right="20.0" />
                     </padding>
                  </HBox>

                  <!-- ─────────────────────────────────────────────────────
                       BOUTONS BAS — description de chaque bouton :

                       ⚡ Vitesse       → cycle 0.5x / 1x / 1.25x / 1.5x / 2x
                       🔓 Verrouiller  → bloque play + slider (anti-clic accidentel)
                                          les contrôles restent visibles quand verrouillé
                       📋 Épisodes     → retourne à la fiche série (EpisodeView)
                                          pour choisir un autre épisode ou saison
                       🎧 Audio/UT     → menu contextuel langue audio + sous-titres
                       ⛶ Plein écran  → toggle plein écran / mode fenêtré
                       ⏭ Épisode suiv → charge et lance l'épisode suivant
                                          de la même saison automatiquement
                  ───────────────────────────────────────────────────────── -->
                  <HBox alignment="CENTER" prefHeight="70.0" spacing="25.0">
                     <children>

                        <!-- Vitesse de lecture -->
                        <Button
                            fx:id="vitesseButton"
                            mnemonicParsing="false"
                            onAction="#handleVitesse"
                            style="-fx-background-color: transparent;"
                            text="⚡ Vitesse"
                            textFill="WHITE">
                           <font><Font size="14.0" /></font>
                        </Button>

                        <!-- Verrouiller les contrôles -->
                        <Button
                            fx:id="lockButton"
                            mnemonicParsing="false"
                            onAction="#handleVerrouiller"
                            style="-fx-background-color: transparent;"
                            text="🔓 Verrouiller"
                            textFill="WHITE">
                           <font><Font size="14.0" /></font>
                        </Button>

                        <!--
                            📋 ÉPISODES
                            Retourne à la fiche de la série (EpisodeView / episodeView screen)
                            pour permettre à l'utilisateur de :
                              - voir la liste de tous les épisodes de la saison
                              - changer de saison
                              - revenir à la description de la série
                        -->
                        <Button
                            mnemonicParsing="false"
                            onAction="#handleOpenEpisodes"
                            style="-fx-background-color: transparent;"
                            text="📋 Épisodes"
                            textFill="WHITE">
                           <font><Font size="14.0" /></font>
                        </Button>

                        <!-- Audio et sous-titres -->
                        <Button
                            mnemonicParsing="false"
                            onAction="#handleAudioMenu"
                            style="-fx-background-color: transparent;"
                            text="🎧 Audio/UT"
                            textFill="WHITE">
                           <font><Font size="14.0" /></font>
                        </Button>

                        <!-- Plein écran -->
                        <Button
                            fx:id="fullscreenButton"
                            mnemonicParsing="false"
                            onAction="#handleFullscreen"
                            style="-fx-background-color: transparent;"
                            text="⛶ Plein écran"
                            textFill="WHITE">
                           <font><Font size="14.0" /></font>
                        </Button>

                        <!--
                            ⏭ ÉPISODE SUIVANT
                            Charge automatiquement l'épisode suivant dans la même saison.
                            Si c'est le dernier épisode, affiche un message "Fin de saison".
                        -->
                        <Button
                            mnemonicParsing="false"
                            onAction="#handleNextEpisode"
                            style="-fx-background-color: transparent;"
                            text="Épisode suivant ⏭"
                            textFill="WHITE">
                           <font><Font name="System Bold" size="14.0" /></font>
                        </Button>

                     </children>
                     <padding>
                        <Insets bottom="10.0" />
                     </padding>
                  </HBox>

               </children>
            </VBox>
         </bottom>

      </BorderPane>
      <Label
    fx:id="subtitleLabel"
    alignment="CENTER"
    maxWidth="700"
    wrapText="true"
    textFill="WHITE"
    style="-fx-font-size:18px; -fx-font-weight:bold;
           -fx-background-color:rgba(0,0,0,0.6);
           -fx-padding:6 12 6 12; -fx-background-radius:6;"
    StackPane.alignment="BOTTOM_CENTER"
    translateY="-60"
    visible="false"/>

   </children>
</StackPane>
