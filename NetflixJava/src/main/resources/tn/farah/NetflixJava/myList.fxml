<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.farah.NetflixJava.Controller.MyListController"
            style="-fx-background-color: #141414;">

    <!-- ═══ NAVBAR ═══ -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-padding: 16 48 16 48;
                     -fx-background-color: #141414;
                     -fx-border-color: transparent transparent #2a2a2a transparent;
                     -fx-border-width: 1px;">

            <!-- Logo -->
            <Label text="NETFLIX"
                   style="-fx-font-family: 'Arial Black'; -fx-font-size: 26px; -fx-font-weight: 900;
                          -fx-text-fill: #E50914;" />

            <!-- Nav links -->
            <HBox alignment="CENTER_LEFT" spacing="28" style="-fx-padding: 0 0 0 40;">
                <Button onAction="#onHome" text="Home"
                        style="-fx-background-color: transparent; -fx-text-fill: #b3b3b3;
                               -fx-font-family: 'Arial'; -fx-font-size: 14px;
                               -fx-cursor: hand; -fx-border-color: transparent;" />
                <Button onAction="#onMovies" text="Movies"
                        style="-fx-background-color: transparent; -fx-text-fill: #b3b3b3;
                               -fx-font-family: 'Arial'; -fx-font-size: 14px;
                               -fx-cursor: hand; -fx-border-color: transparent;" />
                <Button onAction="#onSeries" text="TV Shows"
                        style="-fx-background-color: transparent; -fx-text-fill: #b3b3b3;
                               -fx-font-family: 'Arial'; -fx-font-size: 14px;
                               -fx-cursor: hand; -fx-border-color: transparent;" />
                <!-- My List — highlighted white (current page) -->
                <Button text="My List"
                        style="-fx-background-color: transparent; -fx-text-fill: #ffffff;
                               -fx-font-family: 'Arial'; -fx-font-size: 14px; -fx-font-weight: bold;
                               -fx-cursor: hand; -fx-border-color: transparent;" />
            </HBox>

            <Region HBox.hgrow="ALWAYS" />

            <!-- User greeting -->
            <Label fx:id="lblUserName"
                   style="-fx-font-family: 'Arial'; -fx-font-size: 13px;
                          -fx-text-fill: #b3b3b3; -fx-padding: 0 16 0 0;" />

            <Button onAction="#onBack" text="← Retour"
                    style="-fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: #ffffff;
                           -fx-font-family: 'Arial'; -fx-font-size: 13px;
                           -fx-padding: 8 18 8 18; -fx-background-radius: 4px;
                           -fx-border-color: rgba(255,255,255,0.25); -fx-border-radius: 4px;
                           -fx-border-width: 1px; -fx-cursor: hand;" />
        </HBox>
    </top>

    <!-- ═══ MAIN CONTENT ═══ -->
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    style="-fx-background: #141414; -fx-background-color: #141414;
                           -fx-border-color: transparent;">
            <VBox spacing="48" style="-fx-padding: 40 48 60 48; -fx-background-color: #141414;">

                <!-- ══ PAGE TITLE ══ -->
                <Label text="My List"
                       style="-fx-font-family: 'Arial Black'; -fx-font-size: 32px;
                              -fx-font-weight: 900; -fx-text-fill: #ffffff;" />

                <!-- ══ SECTION 1 : CONTINUE WATCHING ══ -->
                <VBox spacing="16">
                    <Label text="Continue Watching"
                           style="-fx-font-family: 'Arial'; -fx-font-size: 20px; -fx-font-weight: bold;
                                  -fx-text-fill: #ffffff;" />

                    <!-- Cards row — populated by controller -->
                    <HBox fx:id="continueWatchingRow" spacing="12" alignment="CENTER_LEFT"
                          style="-fx-padding: 4 0 12 0;" />

                    <!-- Empty state (shown when no history) -->
                    <Label fx:id="lblNoContinue" text="Nothing in progress yet."
                           style="-fx-font-family: 'Arial'; -fx-font-size: 14px;
                                  -fx-text-fill: #555555; -fx-padding: 20 0 0 0;"
                           managed="false" visible="false" />
                </VBox>

                <!-- ══ SECTION 2 : LIKED / FAVORIS ══ -->
                <VBox spacing="16">
                    <Label text="TV Shows &amp; Movies You've Liked"
                           style="-fx-font-family: 'Arial'; -fx-font-size: 20px; -fx-font-weight: bold;
                                  -fx-text-fill: #ffffff;" />

                    <!-- Cards row — populated by controller -->
                    <HBox fx:id="likedRow" spacing="12" alignment="CENTER_LEFT"
                          style="-fx-padding: 4 0 12 0;" />

                    <!-- Empty state -->
                    <Label fx:id="lblNoLiked" text="You haven't liked anything yet."
                           style="-fx-font-family: 'Arial'; -fx-font-size: 14px;
                                  -fx-text-fill: #555555; -fx-padding: 20 0 0 0;"
                           managed="false" visible="false" />
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
