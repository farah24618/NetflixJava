<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane style="-fx-background-color: #141414;" stylesheets="@../css/style.css" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="tn.farah.NetflixJava.Controller.MyListController">

    <!-- ===== TOP BAR ===== -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="24" style="-fx-background-color: linear-gradient(to bottom, #000000cc, transparent);                      -fx-padding: 18 40 18 40;">
            <Label style="-fx-text-fill: #e50914; -fx-font-size: 28px; -fx-font-weight: bold;" text="RAKCHANET" />
            <HBox alignment="CENTER_LEFT" spacing="18">
                <Label onMouseClicked="#goHome" style="-fx-text-fill: #e5e5e5; -fx-font-size: 14px; -fx-cursor: hand;" text="Accueil" />
                <Label style="-fx-text-fill: #e5e5e5; -fx-font-size: 14px; -fx-cursor: hand;" text="Séries" />
                <Label style="-fx-text-fill: #e5e5e5; -fx-font-size: 14px; -fx-cursor: hand;" text="Films" />
                <Label style="-fx-text-fill: #ffffff; -fx-font-size: 14px; -fx-font-weight: bold;" text="Ma Liste" />
            </HBox>
            <Region HBox.hgrow="ALWAYS" />
            <TextField fx:id="searchField" onAction="#handleSearch" promptText="Rechercher..." style="-fx-background-color: #333; -fx-text-fill: white;                               -fx-prompt-text-fill: #888; -fx-border-color: #555;                               -fx-border-radius: 4; -fx-background-radius: 4;                               -fx-padding: 6 12; -fx-font-size: 13px; -fx-pref-width: 200;" />
        </HBox>
    </top>

    <!-- ===== CENTRE ===== -->
    <center>
        <VBox spacing="0">

            <!-- En-tête de page -->
            <VBox style="-fx-padding: 60 40 24 40;">
                <Label style="-fx-text-fill: white; -fx-font-size: 36px; -fx-font-weight: bold;" text="Ma Liste" />
                <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-padding: 12 0 0 0;">
                    <Label fx:id="totalLabel" style="-fx-text-fill: #aaa; -fx-font-size: 14px;" text="0 titre(s)" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label style="-fx-text-fill: #aaa; -fx-font-size: 13px;" text="Filtrer :" />
                    <ComboBox fx:id="filterType" onAction="#applyFilters" promptText="Type" style="-fx-background-color: #333; -fx-text-fill: white;                                      -fx-border-color: #555; -fx-border-radius: 4; -fx-pref-width: 110;" />
                    <ComboBox fx:id="filterGenre" onAction="#applyFilters" promptText="Genre" style="-fx-background-color: #333; -fx-text-fill: white;                                      -fx-border-color: #555; -fx-border-radius: 4; -fx-pref-width: 140;" />
                    <ComboBox fx:id="sortCombo" onAction="#applyFilters" promptText="Trier par" style="-fx-background-color: #333; -fx-text-fill: white;                                      -fx-border-color: #555; -fx-border-radius: 4; -fx-pref-width: 150;" />
                    <Button onAction="#resetFilters" style="-fx-background-color: transparent; -fx-text-fill: #aaa;                                    -fx-border-color: #555; -fx-border-radius: 4;                                    -fx-padding: 5 12; -fx-cursor: hand; -fx-font-size: 12px;" text="Réinitialiser" />
                </HBox>
            </VBox>

            <!-- État vide -->
            <VBox fx:id="emptyState" alignment="CENTER" managed="false" spacing="16" style="-fx-padding: 80 40; -fx-min-height: 340;" visible="false">
                <Label style="-fx-font-size: 64px; -fx-text-fill: #555;" text="☰" />
                <Label style="-fx-text-fill: #aaa; -fx-font-size: 22px; -fx-font-weight: bold;" text="Votre liste est vide" />
                <Label style="-fx-text-fill: #666; -fx-font-size: 14px;" styleClass="empty-message" text="Ajoutez des films et séries en cliquant sur + depuis leur page." />
                <Button onAction="#goHome" style="-fx-background-color: white; -fx-text-fill: black;                                -fx-font-size: 14px; -fx-font-weight: bold;                                -fx-padding: 10 24; -fx-background-radius: 4;                                -fx-cursor: hand; -fx-pref-width: 220;" text="Parcourir le catalogue" />
            </VBox>

            <!-- pageContainer — carousels injectés ici dynamiquement -->
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background: #141414; -fx-background-color: #141414;                                -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
                <VBox fx:id="pageContainer" spacing="0" style="-fx-background-color: #141414; -fx-padding: 0 0 40 0;" />
            </ScrollPane>

        </VBox>
    </center>

</BorderPane>
