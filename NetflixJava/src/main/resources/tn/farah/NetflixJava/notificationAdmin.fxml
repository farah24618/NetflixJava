<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="900" prefWidth="1340" style="-fx-background-color: #0d0d0d;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.farah.NetflixJava.Controller.NotificationsAdminController">

    <left>
        <VBox prefWidth="280.0" spacing="0" style="-fx-background-color: #000000;">
            <children>

                <HBox alignment="CENTER_LEFT" style="-fx-padding: 30 10 30 20;">
                    <children>
                        <Label minWidth="-Infinity" style="-fx-text-fill: #E50914; -fx-font-size: 20px; -fx-font-weight: bold; -fx-font-family: 'Arial Black';" text="RAKSHANET ADMIN" />
                    </children>
                </HBox>
    
                <Label style="-fx-text-fill: white; -fx-padding: 10 0 15 25;" text="Navigation">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>
    
                <VBox spacing="5" style="-fx-padding: 0 15 0 15;">
                    <children>
                        <Button fx:id="btnDashboard" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" onAction="#onDashboardClicked" style="-fx-background-color: transparent; -fx-text-fill: #888888; -fx-cursor: HAND; -fx-background-radius: 10; -fx-padding: 12 15;" text="⊞   Dashboard">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Button>
    
                        <Button fx:id="btnFilms" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" onAction="#onFilmsClicked" style="-fx-background-color: transparent; -fx-text-fill: #888888; -fx-cursor: HAND; -fx-background-radius: 10; -fx-padding: 12 15;" text="🎬   Films">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Button>

                        <Button fx:id="btnSeries" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" onAction="#onSeriesClicked" style="-fx-background-color: transparent; -fx-text-fill: #888888; -fx-cursor: HAND; -fx-background-radius: 10; -fx-padding: 12 15;" text="📺   Séries">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Button>
    
                        <Button fx:id="btnUsers" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" onAction="#onUsersClicked" style="-fx-background-color: transparent; -fx-text-fill: #888888; -fx-cursor: HAND; -fx-background-radius: 10; -fx-padding: 12 15;" text="👤   Utilisateurs">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Button>
    
                        <Button fx:id="btnNotifications" alignment="CENTER" maxWidth="1.7976931348623157E308" style="-fx-background-color: #E50914; -fx-background-radius: 10; -fx-padding: 12 15; -fx-cursor: HAND;" text="" textFill="WHITE">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" prefWidth="200.0">
                                    <children>
                                        <Label style="-fx-text-fill: white; -fx-font-size: 16px;" text="🔔" />
                                        <Label style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 0 0 0 12;" text="Notifications" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label alignment="CENTER" minWidth="24.0" style="-fx-background-color: white; -fx-text-fill: #E50914; -fx-font-size: 11px; -fx-font-weight: bold; -fx-background-radius: 12; -fx-padding: 2 6 2 6;" text="n°Noti" />
                                    </children>
                                </HBox>
                            </graphic>
                        </Button>
    
                        <Button fx:id="btnComments" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" onAction="#onCommentsClicked" style="-fx-background-color: transparent; -fx-text-fill: #888888; -fx-cursor: HAND; -fx-background-radius: 10; -fx-padding: 12 15;" text="💬   Commentaires">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Button>
    
                        <Button fx:id="btnSettings" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" onAction="#onSettingsClicked" style="-fx-background-color: transparent; -fx-text-fill: #888888; -fx-cursor: HAND; -fx-background-radius: 10; -fx-padding: 12 15;" text="⚙   Paramètres">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Button>
                    </children>
                </VBox>
    
                <Region VBox.vgrow="ALWAYS" />
    
                <Button fx:id="btnLogout" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" onAction="#onLogoutClicked" style="-fx-background-color: transparent; -fx-text-fill: #888888; -fx-cursor: HAND; -fx-padding: 20 25;" text="⏻   Logout">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Button>
            </children>
        </VBox>
    </left>

    <center>
        <VBox spacing="0" style="-fx-background-color: #0d0d0d; -fx-padding: 0 25 25 25;">
            <children>
                <HBox alignment="CENTER_RIGHT" spacing="15" style="-fx-padding: 20 0 20 0;">
                    <children>
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox alignment="CENTER_LEFT" prefWidth="300.0" spacing="10" style="-fx-background-color: #1a1a1a; -fx-background-radius: 10; -fx-padding: 10 15;">
                            <children>
                                <Label style="-fx-text-fill: #666666;" text="🔍" />
                                <TextField fx:id="searchField" onKeyReleased="#onSearch" promptText="Search notifications..." style="-fx-background-color: transparent; -fx-text-fill: white; -fx-prompt-text-fill: #666666;" HBox.hgrow="ALWAYS" />
                            </children>
                        </HBox>
                        <Button fx:id="newNotificationBtn" onAction="#onNewNotification" style="-fx-background-color: #E50914; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 10 20; -fx-cursor: HAND;" text="+ New Notification" />
                    </children>
                </HBox>
    
                <HBox spacing="10" style="-fx-padding: 10 0 20 0;">
                    <children>
                        <Button style="-fx-background-color: #1e1e1e; -fx-text-fill: #888888; -fx-background-radius: 8; -fx-padding: 8 20;">
                            <graphic>
                                <HBox spacing="5">
                                    <Label style="-fx-text-fill: #888888;" text="All" />
                                    <Label fx:id="allCountLabel" style="-fx-text-fill: white;" text="0" />
                                </HBox>
                            </graphic>
                        </Button>
                        <Button style="-fx-background-color: #E50914; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 20;">
                            <graphic>
                                <HBox spacing="5">
                                    <Label style="-fx-text-fill: white;" text="Unread" />
                                    <Label fx:id="unreadCountLabel" style="-fx-text-fill: white;" text="0" />
                                </HBox>
                            </graphic>
                        </Button>
                        <Button style="-fx-background-color: #1e1e1e; -fx-text-fill: #888888; -fx-background-radius: 8; -fx-padding: 8 20;">
                            <graphic>
                                <HBox spacing="5">
                                    <Label style="-fx-text-fill: #888888;" text="Sent" />
                                    <Label fx:id="sentCountLabel" style="-fx-text-fill: white;" text="0" />
                                </HBox>
                            </graphic>
                        </Button>
                    </children>
                </HBox>
    
                <TableView fx:id="notificationsTable" style="-fx-background-color: #141414; -fx-background-radius: 15; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="checkboxColumn" prefWidth="50" resizable="false">
                            <graphic><CheckBox fx:id="selectAllCheckbox" /></graphic>
                        </TableColumn>
                        <TableColumn fx:id="messageColumn" prefWidth="450" text="MESSAGE" />
                        <TableColumn fx:id="userColumn" prefWidth="180" text="USER" />
                        <TableColumn fx:id="dateColumn" prefWidth="150" text="DATE" />
                        <TableColumn fx:id="statusColumn" prefWidth="120" text="STATUS" />
                        <TableColumn fx:id="actionsColumn" prefWidth="150" text="ACTIONS" />
                    </columns>
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                </TableView>
    
                <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-padding: 20 5 0 5;">
                    <children>
                        <Label style="-fx-text-fill: #666666;" text="Showing 1-10 of 385" />
                        <Region HBox.hgrow="ALWAYS" />
                        <ComboBox fx:id="rowsPerPageCombo" prefWidth="70.0" style="-fx-background-color: #1e1e1e; -fx-text-fill: white; -fx-background-radius: 5;">
                            <items>
                                <FXCollections fx:factory="observableArrayList">
                                    <String fx:value="10" /><String fx:value="20" /><String fx:value="50" />
                                </FXCollections>
                            </items>
                        </ComboBox>
                        <HBox spacing="5">
                            <children>
                                <Button minHeight="32" minWidth="32" style="-fx-background-color: #E50914; -fx-text-fill: white; -fx-background-radius: 5;" text="1" />
                                <Button minHeight="32" minWidth="32" style="-fx-background-color: #1e1e1e; -fx-text-fill: #888888; -fx-background-radius: 5;" text="2" />
                            </children>
                        </HBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>
</BorderPane>
