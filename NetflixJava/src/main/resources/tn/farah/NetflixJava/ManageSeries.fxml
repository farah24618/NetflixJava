<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane style="-fx-background-color: #0a0a0c;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.farah.NetflixJava.Controller.SerieController">
    
    <top>
        <HBox style="-fx-background-color: #000000; -fx-padding: 15 25; -fx-border-color: #1a1a1a; -fx-border-width: 0 0 1 0;">
            <Label text="RAKSHANET ADMIN" style="-fx-text-fill: #e50914; -fx-font-size: 22px; -fx-font-weight: bold; -fx-font-family: 'Arial Black';" />
        </HBox>
    </top>

    <left>
        <VBox prefWidth="210" style="-fx-background-color: #000000; -fx-border-color: #1a1a1a; -fx-border-width: 0 1 0 0;">
            <Label text="Navigation" style="-fx-text-fill: #555; -fx-padding: 20 20 10 20; -fx-font-size: 11px; -fx-font-weight: bold;" />
            <VBox spacing="4" style="-fx-padding: 5 12;">
                <Button onAction="#handleNavDashboard" prefWidth="185" alignment="CENTER_LEFT" text="⊞  Tableau de bord" style="-fx-background-color: transparent; -fx-text-fill: #808080; -fx-padding: 10 12;" />
                <Button onAction="#handleNavFilms" prefWidth="185" alignment="CENTER_LEFT" text="🎬  Films" style="-fx-background-color: transparent; -fx-text-fill: #808080; -fx-padding: 10 12;" />
                <Button prefWidth="185" alignment="CENTER_LEFT" text="📺  Séries" style="-fx-background-color: #1a1a1a; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 10 12; -fx-font-weight: bold;" />
                <Button onAction="#handleNavUsers" prefWidth="185" alignment="CENTER_LEFT" text="👤  Utilisateurs" style="-fx-background-color: transparent; -fx-text-fill: #808080; -fx-padding: 10 12;" />
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox spacing="0">
            <HBox alignment="CENTER_LEFT" style="-fx-padding: 20 30; -fx-border-color: #1a1a1a; -fx-border-width: 0 0 1 0;">
                <Label fx:id="seriesCountLabel" text="Mes Séries (0)" style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" />
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#handleNavDashboard" text="Retour Dashboard" style="-fx-background-color: #333333; -fx-text-fill: white; -fx-background-radius: 30; -fx-padding: 10 25; -fx-font-weight: bold;" />
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-padding: 15 30;">
                <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #1a1a1a; -fx-padding: 8 15; -fx-background-radius: 8;" HBox.hgrow="ALWAYS">
                    <Label text="🔍" style="-fx-text-fill: #555;" />
                    <TextField fx:id="searchField" promptText="Rechercher une série..." style="-fx-background-color: transparent; -fx-text-fill: white; -fx-border-color: transparent;" HBox.hgrow="ALWAYS" />
                </HBox>
                <Button text="+ Ajouter une série" style="-fx-background-color: #e50914; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 25; -fx-background-radius: 8;" />
            </HBox>

            <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                <content>
                    <VBox fx:id="seriesListContainer" spacing="2.0" style="-fx-background-color: #0a0a0c;" />
                </content>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>