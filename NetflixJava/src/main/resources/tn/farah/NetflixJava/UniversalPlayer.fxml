<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.media.MediaView?>
<?import javafx.scene.text.Font?>


<StackPane
    fx:id="rootPane"
    prefHeight="450.0"
    prefWidth="800.0"
    style="-fx-background-color: black;"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="tn.farah.NetflixJava.Controller.UniversalPlayerController">

   <children>

      <MediaView fx:id="mediaView" />
      <BorderPane
          fx:id="controlsPane"
          visible="false"
          style="-fx-background-color: rgba(0,0,0,0.0);">

         <top>
            <HBox
                alignment="CENTER_LEFT"
                prefHeight="60.0"
                spacing="20.0"
                style="-fx-background-color: linear-gradient(to bottom, rgba(0,0,0,0.75), transparent);"
                BorderPane.alignment="CENTER">
               <children>
                  <Button
                      mnemonicParsing="false"
                      onAction="#handleRetour"
                      style="-fx-background-color: transparent; -fx-cursor: hand;"
                      text="← Retour"
                      textFill="WHITE">
                     <font><Font name="System Bold" size="15.0" /></font>
                  </Button>
                  <Label fx:id="titleLabel" text="" textFill="WHITE">
                     <font><Font name="System Bold" size="18.0" /></font>
                  </Label>
               </children>
               <padding><Insets left="20.0" top="15.0" /></padding>
            </HBox>
         </top>

         <center>
            <HBox alignment="CENTER" spacing="60.0" BorderPane.alignment="CENTER">
               <children>
                  <Button
                      mnemonicParsing="false"
                      onAction="#rewind10"
                      style="-fx-background-color: transparent;"
                      text="↺ 10"
                      textFill="WHITE">
                     <font><Font size="26.0" /></font>
                  </Button>

                  <Button
                      fx:id="playButton"
                      mnemonicParsing="false"
                      onAction="#handlePlayPause"
                      style="-fx-background-color: transparent;"
                      text="▶"
                      textFill="WHITE">
                     <font><Font size="45.0" /></font>
                  </Button>

                  <Button
                      mnemonicParsing="false"
                      onAction="#forward10"
                      style="-fx-background-color: transparent;"
                      text="10 ↻"
                      textFill="WHITE">
                     <font><Font size="26.0" /></font>
                  </Button>
               </children>
            </HBox>
         </center>

         <bottom>
            <VBox
                alignment="BOTTOM_CENTER"
                prefHeight="140.0"
                spacing="5.0"
                style="-fx-background-color: linear-gradient(to top, rgba(0,0,0,0.75), transparent);"
                BorderPane.alignment="CENTER">
               <children>

                  <!-- "Skip intro" – hidden by default, shown for episodes -->
                  <AnchorPane prefHeight="50.0">
                     <children>
                        <Button
                            fx:id="skipIntroButton"
                            mnemonicParsing="false"
                            onAction="#handleSkipIntro"
                            style="-fx-background-color: rgba(0,0,0,0.75);
                                   -fx-border-color: white;
                                   -fx-border-radius: 5;
                                   -fx-background-radius: 5;
                                   -fx-cursor: hand;"
                            text="⏩  Passer l'intro"
                            textFill="WHITE"
                            visible="false"
                            managed="false"
                            AnchorPane.bottomAnchor="5.0"
                            AnchorPane.rightAnchor="30.0">
                           <padding>
                              <Insets bottom="8.0" left="20.0" right="20.0" top="8.0" />
                           </padding>
                           <font><Font name="System Bold" size="13.0" /></font>
                        </Button>
                     </children>
                  </AnchorPane>

                  <!-- Progress bar + time -->
                  <HBox alignment="CENTER" spacing="15.0">
                     <children>
                        <Slider fx:id="progressBar" HBox.hgrow="ALWAYS" />
                        <Label fx:id="timeLabel" minWidth="110.0" text="00:00 / 00:00" textFill="WHITE" />
                     </children>
                     <padding><Insets left="20.0" right="20.0" /></padding>
                  </HBox>

                 
                  <HBox alignment="CENTER" prefHeight="70.0" spacing="25.0">
                     <children>

                        <Button
                            fx:id="vitesseButton"
                            mnemonicParsing="false"
                            onAction="#handleVitesse"
                            style="-fx-background-color: transparent;"
                            text="⚡ Vitesse"
                            textFill="WHITE">
                           <font><Font size="14.0" /></font>
                        </Button>

                        <Button
                            fx:id="lockButton"
                            mnemonicParsing="false"
                            onAction="#handleVerrouiller"
                            style="-fx-background-color: transparent;"
                            text="🔓 Verrouiller"
                            textFill="WHITE">
                           <font><Font size="14.0" /></font>
                        </Button>

                        <Button
                            mnemonicParsing="false"
                            onAction="#handleAudioMenu"
                            style="-fx-background-color: transparent;"
                            text="🎧 Audio/UT"
                            textFill="WHITE">
                           <font><Font size="14.0" /></font>
                        </Button>

                        <Button
                            fx:id="fullscreenButton"
                            mnemonicParsing="false"
                            onAction="#handleFullscreen"
                            style="-fx-background-color: transparent;"
                            text="⛶ Plein écran"
                            textFill="WHITE">
                           <font><Font size="14.0" /></font>
                        </Button>

                        <Button
                            fx:id="episodesButton"
                            mnemonicParsing="false"
                            onAction="#handleOpenEpisodes"
                            style="-fx-background-color: transparent;"
                            text="📋 Épisodes"
                            textFill="WHITE"
                            visible="false"
                            managed="false">
                           <font><Font size="14.0" /></font>
                        </Button>

                        <Button
                            fx:id="nextEpisodeButton"
                            mnemonicParsing="false"
                            onAction="#handleNextEpisode"
                            style="-fx-background-color: transparent;"
                            text="Épisode suivant ⏭"
                            textFill="WHITE"
                            visible="false"
                            managed="false">
                           <font><Font name="System Bold" size="14.0" /></font>
                        </Button>

                        <Button
                            fx:id="ficheButton"
                            mnemonicParsing="false"
                            onAction="#handleRetour"
                            style="-fx-background-color: transparent;"
                            text="🎬 Fiche"
                            textFill="WHITE"
                            visible="false"
                            managed="false">
                           <font><Font name="System Bold" size="14.0" /></font>
                        </Button>

                     </children>
                     <padding><Insets bottom="10.0" /></padding>
                  </HBox>

               </children>
            </VBox>
         </bottom>

      </BorderPane>

      <!-- Subtitle overlay -->
      <Label
          fx:id="subtitleLabel"
          alignment="CENTER"
          maxWidth="700"
          wrapText="true"
          textFill="WHITE"
          style="-fx-font-size: 18px; -fx-font-weight: bold;
                 -fx-background-color: rgba(0,0,0,0.6);
                 -fx-padding: 6 12 6 12; -fx-background-radius: 6;"
          StackPane.alignment="BOTTOM_CENTER"
          translateY="-60"
          visible="false"/>

   </children>
</StackPane>
