<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.farah.NetflixJava.Controller.DetailMediaController"
            prefWidth="1400.0"
            prefHeight="900.0"
            style="-fx-background-color: black;">

    <!-- TOP BAR -->
    <top>
        <HBox alignment="CENTER_LEFT"
              spacing="20.0"
              prefHeight="70.0"
              style="-fx-background-color: rgba(0,0,0,0.85);">
            <padding>
                <Insets top="10" right="25" bottom="10" left="25"/>
            </padding>

            <children>
                <ImageView fx:id="imgLogo" fitHeight="42.0" preserveRatio="true">
                    <image>
                        <Image url="@/tn/farah/NetflixJava/ImagesNet/logo.png"/>
                    </image>
                </ImageView>

                <Label text="RakshaNet"
                       style="-fx-text-fill: #E50914; -fx-font-size: 24px; -fx-font-weight: bold;"/>

                <Button text="Accueil"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 15px;"/>

                <Button text="Séries"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 15px;"/>

                <Button text="Films"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 15px;"/>

                <Button text="Ma liste"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 15px;"/>

                <Region HBox.hgrow="ALWAYS"/>
            </children>
        </HBox>
    </top>

    <!-- CENTER -->
    <center>
        <VBox spacing="0.0" style="-fx-background-color: black;">

            <!-- HERO SECTION -->
            <StackPane prefHeight="500.0">
                <children>

                    <ImageView fx:id="imgBackground"
                               fitWidth="1400.0"
                               fitHeight="500.0"
                               preserveRatio="false"
                               opacity="0.45"/>

                    <AnchorPane prefWidth="1400.0" prefHeight="500.0">
                        <children>

                            <VBox spacing="18.0"
                                  layoutX="45.0"
                                  layoutY="80.0"
                                  prefWidth="700.0">
                                <children>

                                    <Label fx:id="lblTitre"
                                           text="Titre du média"
                                           style="-fx-text-fill: white; -fx-font-size: 52px; -fx-font-weight: bold;"/>

                                    <HBox spacing="12.0">
                                        <children>
                                            <Label fx:id="lblType"
                                                   text="Série"
                                                   style="-fx-text-fill: #e50914; -fx-font-size: 18px; -fx-font-weight: bold;"/>

                                            <Label text="•"
                                                   style="-fx-text-fill: #bbbbbb; -fx-font-size: 18px;"/>

                                            <Label fx:id="lblNote"
                                                   text="4.8/5"
                                                   style="-fx-text-fill: white; -fx-font-size: 18px;"/>

                                            <Label text="•"
                                                   style="-fx-text-fill: #bbbbbb; -fx-font-size: 18px;"/>

                                            <Label fx:id="lblAnnee"
                                                   text="2025"
                                                   style="-fx-text-fill: white; -fx-font-size: 18px;"/>

                                            <Label text="•"
                                                   style="-fx-text-fill: #bbbbbb; -fx-font-size: 18px;"/>

                                            <Label fx:id="lblCategorie"
                                                   text="Science-fiction"
                                                   style="-fx-text-fill: white; -fx-font-size: 18px;"/>
                                        </children>
                                    </HBox>

                                    <Label fx:id="lblDescription"
                                           text="Description du média..."
                                           wrapText="true"
                                           maxWidth="650.0"
                                           style="-fx-text-fill: white; -fx-font-size: 20px;"/>

                                    <Label fx:id="lblCasting"
                                           text="Casting : Acteur 1, Acteur 2, Acteur 3"
                                           wrapText="true"
                                           maxWidth="650.0"
                                           style="-fx-text-fill: #d0d0d0; -fx-font-size: 16px;"/>

                                    <HBox spacing="14.0">
                                        <children>
                                            <Button fx:id="btnLecture"
                                                    text="▶ Lecture"
                                                    prefWidth="140.0"
                                                    prefHeight="42.0"
                                                    style="-fx-background-color: white; -fx-text-fill: black; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 10;"/>

                                            <Button fx:id="btnMaListe"
                                                    text="+ Ma liste"
                                                    prefWidth="140.0"
                                                    prefHeight="42.0"
                                                    style="-fx-background-color: #2b2b2b; -fx-text-fill: white; -fx-font-size: 16px; -fx-background-radius: 10;"/>
                                        </children>
                                    </HBox>

                                </children>
                            </VBox>

                            <ImageView fx:id="imgAffiche"
                                       fitWidth="280.0"
                                       fitHeight="390.0"
                                       preserveRatio="true"
                                       layoutX="1040.0"
                                       layoutY="60.0"/>
                        </children>
                    </AnchorPane>
                </children>
            </StackPane>

            <!-- MENU -->
            <HBox alignment="CENTER_LEFT"
                  spacing="35.0"
                  prefHeight="70.0"
                  style="-fx-background-color: #111111;">
                <padding>
                    <Insets top="0" right="35" bottom="0" left="35"/>
                </padding>

                <children>
                    <Button fx:id="btnAPropos"
                            text="À propos"
                            style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 20px;"/>

                    <Button fx:id="btnEpisodes"
                            text="Épisodes"
                            visible="true"
                            managed="true"
                            style="-fx-background-color: transparent; -fx-text-fill: #bbbbbb; -fx-font-size: 20px;"/>

                    <Button fx:id="btnBandesAnnonces"
                            text="Bandes-annonces"
                            style="-fx-background-color: transparent; -fx-text-fill: #bbbbbb; -fx-font-size: 20px;"/>

                    <Button fx:id="btnCommentaires"
                            text="Commentaires"
                            style="-fx-background-color: transparent; -fx-text-fill: #bbbbbb; -fx-font-size: 20px;"/>

                    <Button fx:id="btnSimilaires"
                            text="Similaires"
                            style="-fx-background-color: transparent; -fx-text-fill: #bbbbbb; -fx-font-size: 20px;"/>
                </children>
            </HBox>

            <!-- CONTENT AREA -->
            <VBox fx:id="contentContainer"
                  spacing="15.0"
                  style="-fx-background-color: black;"
                  VBox.vgrow="ALWAYS">
                <padding>
                    <Insets top="25" right="35" bottom="25" left="35"/>
                </padding>

                <children>
                    <Label text="Contenu principal de la page détail"
                           style="-fx-text-fill: white; -fx-font-size: 24px;"/>

                    <Label text="Cette zone changera selon l'onglet choisi."
                           wrapText="true"
                           style="-fx-text-fill: #cccccc; -fx-font-size: 18px;"/>
                </children>
            </VBox>

        </VBox>
    </center>

</BorderPane>