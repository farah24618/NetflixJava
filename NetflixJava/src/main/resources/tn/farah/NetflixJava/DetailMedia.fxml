<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.farah.NetflixJava.Controller.DetailMediaController"
            prefWidth="1400.0"
            prefHeight="800.0"
            style="-fx-background-color: linear-gradient(to bottom, #0b0b0b, #141414);">

    <top>
        <HBox alignment="CENTER_LEFT"
              spacing="20.0"
              prefHeight="70.0"
              style="-fx-background-color: rgba(0,0,0,0.75);">
            <padding>
                <Insets top="10" right="25" bottom="10" left="25"/>
            </padding>

            <children>
                <ImageView fx:id="imgLogo" fitHeight="38.0" preserveRatio="true">
                    <image>
                        <Image url="@ImagesNet/ChatGPT%20Image%20Feb%209,%202026,%2005_10_50%20PM.png"/>
                    </image>
                </ImageView>

                <Button text="Accueil"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>

                <Button text="Films"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>

                <Button text="Séries"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="Mon compte"
                        style="-fx-background-color: #E50914; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 8;"/>
            </children>
        </HBox>
    </top>

    <center>
        <StackPane>
            <children>

                <!-- Image de fond -->
                <ImageView fx:id="imgBackground"
                           fitWidth="1400.0"
                           fitHeight="730.0"
                           preserveRatio="false"
                           opacity="0.35"/>

                <!-- Contenu -->
                <HBox spacing="40.0" alignment="CENTER_LEFT">
                    <padding>
                        <Insets top="35" right="50" bottom="35" left="50"/>
                    </padding>

                    <children>

                        <!-- Partie gauche -->
                        <VBox spacing="18.0" prefWidth="700.0">
                            <children>

                                <Label fx:id="lblTitre"
                                       text="Titre du média"
                                       style="-fx-text-fill: white; -fx-font-size: 40px; -fx-font-weight: bold;"/>

                                <HBox spacing="12.0">
                                    <children>
                                        <Label fx:id="lblType"
                                               text="Film"
                                               style="-fx-text-fill: #E50914; -fx-font-size: 15px; -fx-font-weight: bold;"/>

                                        <Label text="|"
                                               style="-fx-text-fill: #B3B3B3; -fx-font-size: 15px;"/>

                                        <Label fx:id="lblNote"
                                               text="8.5/10"
                                               style="-fx-text-fill: white; -fx-font-size: 15px;"/>

                                        <Label text="|"
                                               style="-fx-text-fill: #B3B3B3; -fx-font-size: 15px;"/>

                                        <Label fx:id="lblAnnee"
                                               text="2025"
                                               style="-fx-text-fill: white; -fx-font-size: 15px;"/>

                                        <Label text="|"
                                               style="-fx-text-fill: #B3B3B3; -fx-font-size: 15px;"/>

                                        <Label fx:id="lblCategorie"
                                               text="Action"
                                               style="-fx-text-fill: white; -fx-font-size: 15px;"/>
                                    </children>
                                </HBox>

                                <Label text="Synopsis"
                                       style="-fx-text-fill: #E5E5E5; -fx-font-size: 18px; -fx-font-weight: bold;"/>

                                <Label fx:id="lblDescription"
                                       text="Description du média..."
                                       wrapText="true"
                                       maxWidth="650.0"
                                       style="-fx-text-fill: #D2D2D2; -fx-font-size: 16px; -fx-line-spacing: 4px;"/>

                                <Label text="Casting"
                                       style="-fx-text-fill: #E5E5E5; -fx-font-size: 18px; -fx-font-weight: bold;"/>

                                <Label fx:id="lblCasting"
                                       text="Acteur 1, Acteur 2, Acteur 3"
                                       wrapText="true"
                                       maxWidth="650.0"
                                       style="-fx-text-fill: #D2D2D2; -fx-font-size: 15px;"/>

                                <HBox spacing="15.0">
                                    <children>
                                        <Button fx:id="btnWatch"
                                                text="▶ Regarder"
                                                prefWidth="150.0"
                                                prefHeight="42.0"
                                                style="-fx-background-color: white; -fx-text-fill: black; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 8;"/>

                                        <Button fx:id="btnTrailer"
                                                text="Trailer"
                                                prefWidth="120.0"
                                                prefHeight="42.0"
                                                style="-fx-background-color: rgba(255,255,255,0.20); -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 8;"/>

                                        <Button fx:id="btnFavori"
                                                text="+ Ma liste"
                                                prefWidth="130.0"
                                                prefHeight="42.0"
                                                style="-fx-background-color: rgba(255,255,255,0.20); -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 8;"/>
                                    </children>
                                </HBox>

                                <VBox fx:id="serieBox"
                                      spacing="10.0"
                                      visible="false"
                                      managed="false"
                                      style="-fx-background-color: rgba(255,255,255,0.06); -fx-background-radius: 12; -fx-padding: 15;">
                                    <children>
                                        <Label text="Saisons"
                                               style="-fx-text-fill: white; -fx-font-size: 17px; -fx-font-weight: bold;"/>

                                        <ComboBox fx:id="cbSaisons"
                                                  prefWidth="220.0"
                                                  style="-fx-background-color: #2A2A2A; -fx-text-fill: white;"/>

                                        <Label text="Episodes"
                                               style="-fx-text-fill: white; -fx-font-size: 17px; -fx-font-weight: bold;"/>

                                        <ListView fx:id="listEpisodes"
                                                  prefHeight="180.0"
                                                  prefWidth="500.0"
                                                  VBox.vgrow="ALWAYS"
                                                  style="-fx-background-color: #1B1B1B; -fx-control-inner-background: #1B1B1B; -fx-text-fill: white;"/>
                                    </children>
                                </VBox>

                            </children>
                        </VBox>

                        <!-- Partie droite -->
                        <VBox alignment="CENTER" prefWidth="420.0">
                            <children>
                                <ImageView fx:id="imgAffiche"
                                           fitWidth="360.0"
                                           fitHeight="520.0"
                                           preserveRatio="true"/>
                            </children>
                        </VBox>

                    </children>
                </HBox>
            </children>
        </StackPane>
    </center>

</BorderPane>