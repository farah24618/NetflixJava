<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="750.0" prefWidth="1200.0" style="-fx-background-color: #050505;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.farah.NetflixJava.Controller.ManageUsersController">
    
    <left>
        <VBox prefWidth="280.0" spacing="0" style="-fx-background-color: #000000; -fx-border-color: #1a1a1a; -fx-border-width: 0 1 0 0;">
            <children>
                <HBox alignment="CENTER_LEFT" style="-fx-padding: 30 10 30 20;">
                    <children>
                        <Label minWidth="-Infinity" style="-fx-text-fill: #E50914; -fx-font-size: 20px; -fx-font-weight: bold; -fx-font-family: 'Arial Black';" text="RAKSHANET ADMIN" />
                    </children>
                </HBox>
    
                <Label style="-fx-text-fill: white; -fx-padding: 10 0 15 25;" text="Navigation">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>
    
                <VBox spacing="5" style="-fx-padding: 0 15 0 15;">
                    <children>
                        <Button fx:id="btnDashboard" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" onAction="#handleNavDashboard" style="-fx-background-color: transparent; -fx-text-fill: #888888; -fx-cursor: HAND; -fx-background-radius: 10; -fx-padding: 12 15;" text="⊞   Dashboard">
                            <font><Font size="14.0" /></font>
                        </Button>
                        
                        <Button fx:id="btnFilms" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" onAction="#handleNavFilms" style="-fx-background-color: transparent; -fx-text-fill: #888888; -fx-cursor: HAND; -fx-background-radius: 10; -fx-padding: 12 15;" text="🎬  Films">
                            <font><Font size="14.0" /></font>
                        </Button>
                        
                        <Button fx:id="btnSeries" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" onAction="#handleNavSeries" style="-fx-background-color: transparent; -fx-text-fill: #888888; -fx-cursor: HAND; -fx-background-radius: 10; -fx-padding: 12 15;" text="📺  Séries">
                            <font><Font size="14.0" /></font>
                        </Button>
                        
                        <Button fx:id="btnUsers" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" style="-fx-background-color: #E50914; -fx-text-fill: white; -fx-cursor: HAND; -fx-background-radius: 10; -fx-padding: 12 15; -fx-font-weight: bold;" text="👤  Utilisateurs">
                            <font><Font size="14.0" /></font>
                        </Button>
                        
                        <Button fx:id="btnNotifications" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" onAction="#handleNavNotifications" style="-fx-background-color: transparent; -fx-text-fill: #888888; -fx-cursor: HAND; -fx-background-radius: 10; -fx-padding: 12 15;" text="🔔  Notifications">
                            <font><Font size="14.0" /></font>
                        </Button>
                        
                        <Button fx:id="btnComments" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" onAction="#handleNavComments" style="-fx-background-color: transparent; -fx-text-fill: #888888; -fx-cursor: HAND; -fx-background-radius: 10; -fx-padding: 12 15;" text="💬  Commentaires">
                            <font><Font size="14.0" /></font>
                        </Button>
                        
                        <Button fx:id="btnSettings" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" onAction="#handleNavSettings" style="-fx-background-color: transparent; -fx-text-fill: #888888; -fx-cursor: HAND; -fx-background-radius: 10; -fx-padding: 12 15;" text="⚙   Paramètres">
                            <font><Font size="14.0" /></font>
                        </Button>
                    </children>
                </VBox>
            </children>
        </VBox>
    </left>

    <center>
        <VBox spacing="0">
            <HBox alignment="CENTER_LEFT" style="-fx-padding: 30 40 10 40;">
                <Label text="Gestion Utilisateurs" style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;" />
                <Region HBox.hgrow="ALWAYS" />
            </HBox>

            <VBox spacing="20" style="-fx-padding: 20 40;">
                <HBox alignment="CENTER_LEFT" spacing="20">
                    <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: #1a1a1a; -fx-background-radius: 8; -fx-padding: 12 20; -fx-border-color: #333; -fx-border-radius: 8;" HBox.hgrow="ALWAYS">
                        <Label style="-fx-text-fill: #666; -fx-font-size: 16px;" text="🔍" />
                        <TextField fx:id="searchField" promptText="Rechercher un utilisateur..." style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px;" HBox.hgrow="ALWAYS" />
                    </HBox>
                </HBox>
                
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Button fx:id="tabAll" onAction="#handleTabAll" text="Tous" style="-fx-background-color: #e50914; -fx-text-fill: white; -fx-background-radius: 5; -fx-padding: 8 20; -fx-cursor: hand;" />
                    <Button fx:id="tabAdmins" onAction="#handleTabAdmins" text="Administrateurs" style="-fx-background-color: #1a1a1a; -fx-text-fill: #808080; -fx-background-radius: 5; -fx-padding: 8 20; -fx-cursor: hand;" />
                    <Button fx:id="tabBlocked" onAction="#handleTabBlocked" text="Bloqués" style="-fx-background-color: #1a1a1a; -fx-text-fill: #808080; -fx-background-radius: 5; -fx-padding: 8 20; -fx-cursor: hand;" />
                    <Region HBox.hgrow="ALWAYS" />
                    <ComboBox fx:id="sortCombo" prefWidth="150" promptText="Trier par" style="-fx-background-color: #1a1a1a; -fx-border-color: #333; -fx-text-fill: white;" />
                </HBox>
            </VBox>

            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
                <content>
                    <VBox fx:id="usersContainer" spacing="5.0" style="-fx-background-color: transparent; -fx-padding: 10 40;" />
                </content>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>