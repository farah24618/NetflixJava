<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<BorderPane style="-fx-background-color: #0a0a0c;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.farah.NetflixJava.Controller.ManageUsersController">
    <left>
        <VBox prefWidth="200" spacing="0" style="-fx-background-color: #000000; -fx-border-color: #1a1a1a; -fx-border-width: 0 1 0 0;">
            <VBox spacing="2" style="-fx-padding: 25 20;">
                <Label text="RAKSHANET" style="-fx-text-fill: #e50914; -fx-font-size: 18px; -fx-font-weight: bold; -fx-font-family: 'Arial Black';" />
                <Label text="ADMIN" style="-fx-text-fill: #e50914; -fx-font-size: 14px; -fx-font-weight: bold;" />
            </VBox>

            <Label text="Navigation" style="-fx-text-fill: #555; -fx-padding: 10 20; -fx-font-size: 11px; -fx-font-weight: bold; -fx-letter-spacing: 1px;" />

            <VBox spacing="4" style="-fx-padding: 5 12;">
                <Button onAction="#handleNavDashboard" prefWidth="176" alignment="CENTER_LEFT" text="⊞  Tableau de bord" style="-fx-background-color: transparent; -fx-text-fill: #808080; -fx-cursor: hand; -fx-padding: 10 12;" />
                <Button onAction="#handleNavFilms" prefWidth="176" alignment="CENTER_LEFT" text="🎬  Films" style="-fx-background-color: transparent; -fx-text-fill: #808080; -fx-cursor: hand; -fx-padding: 10 12;" />
                <Button onAction="#handleNavSeries" prefWidth="176" alignment="CENTER_LEFT" text="📺  Séries" style="-fx-background-color: transparent; -fx-text-fill: #808080; -fx-cursor: hand; -fx-padding: 10 12;" />
                <Button prefWidth="176" alignment="CENTER_LEFT" text="👤  Utilisateurs" style="-fx-background-color: #1a1a1a; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 10 12; -fx-font-weight: bold;" />
                <Button onAction="#handleNavNotifications" prefWidth="176" alignment="CENTER_LEFT" text="🔔  Notifications" style="-fx-background-color: transparent; -fx-text-fill: #808080; -fx-cursor: hand; -fx-padding: 10 12;" />
                <Button onAction="#handleNavComments" prefWidth="176" alignment="CENTER_LEFT" text="💬  Commentaires" style="-fx-background-color: transparent; -fx-text-fill: #808080; -fx-cursor: hand; -fx-padding: 10 12;" />
                <Button onAction="#handleNavSettings" prefWidth="176" alignment="CENTER_LEFT" text="⚙  Paramètres" style="-fx-background-color: transparent; -fx-text-fill: #808080; -fx-cursor: hand; -fx-padding: 10 12;" />
            </VBox>
            
            <Region VBox.vgrow="ALWAYS" />
            <Button onAction="#handleLogout" prefWidth="200" alignment="CENTER_LEFT" text="⏻  Déconnexion" style="-fx-background-color: transparent; -fx-text-fill: #808080; -fx-padding: 20; -fx-cursor: hand;" />
        </VBox>
    </left>

    <center>
        <VBox spacing="0">
            <HBox alignment="CENTER_LEFT" style="-fx-padding: 20 30; -fx-border-color: #1a1a1a; -fx-border-width: 0 0 1 0;">
                <Label text="Utilisateurs" style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" />
                <Region HBox.hgrow="ALWAYS" />
                
                <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #1a1a1a; -fx-padding: 8 15; -fx-background-radius: 8; -fx-border-color: #2a2a2a; -fx-border-radius: 8;">
                    <Label text="🔍" style="-fx-text-fill: #555;" />
                    <TextField fx:id="searchField" promptText="Rechercher..." style="-fx-background-color: transparent; -fx-text-fill: white; -fx-border-color: transparent;" />
                </HBox>
                
                <Button onAction="#handleNavDashboard" text="Retour Dashboard" 
                        style="-fx-background-color: #333333; -fx-text-fill: white; -fx-background-radius: 25; -fx-padding: 9 22; -fx-font-weight: bold; -fx-cursor: hand;">
                    <HBox.margin><Insets left="15" /></HBox.margin>
                </Button>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 15 30;">
                <Button fx:id="tabAll" onAction="#handleTabAll" text="Tous" />
                <Button fx:id="tabAdmins" onAction="#handleTabAdmins" text="Administrateurs" />
                <Button fx:id="tabBlocked" onAction="#handleTabBlocked" text="Bloqués" />
                <Region HBox.hgrow="ALWAYS" />
                <ComboBox fx:id="sortCombo" onAction="#handleSort" promptText="Trier par" prefWidth="150" style="-fx-background-color: #1a1a1a; -fx-text-fill: white; -fx-border-color: #2a2a2a; -fx-border-radius: 6;" />
            </HBox>

            <HBox spacing="0" style="-fx-padding: 10 30; -fx-background-color: #0f0f13; -fx-border-color: #1a1a1a; -fx-border-width: 1 0 1 0;">
                <Label minWidth="40" text=" " />
                <Label minWidth="160" text="UTILISATEUR" style="-fx-text-fill: #555; -fx-font-size: 10px; -fx-font-weight: bold; -fx-letter-spacing: 1px;" />
                <Label minWidth="200" text="EMAIL" style="-fx-text-fill: #555; -fx-font-size: 10px; -fx-font-weight: bold; -fx-letter-spacing: 1px;" />
                <Label minWidth="100" text="STATUT" style="-fx-text-fill: #555; -fx-font-size: 10px; -fx-font-weight: bold; -fx-letter-spacing: 1px;" alignment="CENTER" />
                <Label minWidth="260" text="ACTIONS" style="-fx-text-fill: #555; -fx-font-size: 10px; -fx-font-weight: bold; -fx-letter-spacing: 1px;" alignment="CENTER" />
            </HBox>

            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
                <VBox fx:id="usersContainer" style="-fx-background-color: #0a0a0c;" />
            </ScrollPane>

            <HBox alignment="CENTER_LEFT" style="-fx-padding: 12 30; -fx-background-color: #0f0f13; -fx-border-color: #1a1a1a; -fx-border-width: 1 0 0 0;">
                <Label fx:id="showingLabel" text="Affichage 1-10 sur 0" style="-fx-text-fill: #555; -fx-font-size: 12px;" />
                <Region HBox.hgrow="ALWAYS" />
                <Label text="Lignes par page " style="-fx-text-fill: #555; -fx-font-size: 12px;" />
                <ComboBox fx:id="rowsPerPageCombo" prefWidth="70" style="-fx-background-color: #1a1a1a; -fx-text-fill: white;" />
            </HBox>
        </VBox>
    </center>
</BorderPane>