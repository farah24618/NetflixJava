<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane style="-fx-background-color: #141414;" stylesheets="@home.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.farah.NetflixJava.Controller.HomeController">

    <BorderPane.styleClass>
        <!-- Les styles lourds sont dans home.css désormais -->
    </BorderPane.styleClass>

    <!-- ═══ NAVBAR ═══ -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="0" styleClass="navbar">

            <Label styleClass="logo" text="RAKCHANET" />

            <HBox alignment="CENTER_LEFT" spacing="20" styleClass="nav-links">
                <Button onAction="#onMyList" styleClass="nav-btn" text="Ma_liste" />
                <Button onAction="#onMovies" styleClass="nav-btn" text="Films" />
                <Button onAction="#onSeries" styleClass="nav-btn" text="Series" />
            </HBox>

            <Region HBox.hgrow="ALWAYS" />

            <HBox alignment="CENTER" spacing="18">
                <HBox alignment="CENTER" spacing="6">
                    <TextField fx:id="searchField" onKeyReleased="#onSearch" prefWidth="200" promptText="titres" styleClass="search-field" />
                    <Button onAction="#onSearchBtn" styleClass="icon-btn" text="🔍" />
                </HBox>
               <StackPane>
    <Button onAction="#onNotifications" styleClass="icon-btn" text="🔔" />
    <Label fx:id="notifBadge" style="-fx-background-color: #E50914;                   -fx-text-fill: white;                   -fx-background-radius: 10;                   -fx-font-size: 10px;                   -fx-padding: 1 5 1 5;                   -fx-font-weight: bold;" visible="false" StackPane.alignment="TOP_RIGHT" />
</StackPane>
                <StackPane styleClass="avatar-box">
                    <Label fx:id="avatarLabel" styleClass="avatar-label" text="U" />
                </StackPane>
            </HBox>

        </HBox>
    </top>

    <!-- ═══ CONTENU ═══ -->
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="main-scroll" vbarPolicy="AS_NEEDED">
            <VBox spacing="0">

                <!-- ── HERO ── -->
                <StackPane fx:id="heroSection" alignment="BOTTOM_LEFT" styleClass="hero-section">

                    <Pane fx:id="heroBackdrop" styleClass="hero-backdrop" />

                    <!-- Dégradé statique : purement visuel, il reste dans le FXML -->
                    <Pane mouseTransparent="true" styleClass="hero-gradient" />

                    <!-- Contenu texte -->
                    <VBox fx:id="heroContent" alignment="BOTTOM_LEFT" maxWidth="550" spacing="12" styleClass="hero-content">

                        <Label fx:id="heroTitle" styleClass="hero-title" wrapText="true" />
                        <Label fx:id="heroSynopsis" styleClass="hero-synopsis" wrapText="true" />
                  <Label fx:id="heroCategories" />

                        <!-- Boutons d'action -->
                        <HBox spacing="12" styleClass="hero-actions">
                            <Button onAction="#onPlayFeatured" styleClass="btn-play" text="▶  Lire">
                        <cursor>
                           <Cursor fx:constant="HAND" />
                        </cursor></Button>
                            <Button onAction="#onMoreInfoFeatured" styleClass="btn-info" text="ℹ  Plus d'info">
                        <cursor>
                           <Cursor fx:constant="HAND" />
                        </cursor></Button>
                        </HBox>

                        <!-- Méta-données -->
                        <HBox fx:id="heroMeta" alignment="CENTER_LEFT" spacing="14">
                            <Label fx:id="heroRating" styleClass="hero-rating" />
                            <Label fx:id="heroDuration" styleClass="hero-meta-lbl" />
                            <Label fx:id="heroYear" styleClass="hero-meta-lbl" />
                            <Label fx:id="heroCertif" styleClass="hero-certif" />
                            <Label fx:id="heroType" styleClass="hero-meta-lbl" />
                            <Label fx:id="heroGenreBadge" styleClass="hero-meta-lbl" />
                        </HBox>
                    </VBox>

                    <!-- Badge âge (top-right) -->
                    <HBox alignment="CENTER_RIGHT" styleClass="age-badge-box" StackPane.alignment="CENTER_RIGHT">
                        <Label fx:id="heroWarning" styleClass="age-badge" text="19+" />
                    </HBox>

                </StackPane>

                <!-- ── CAROUSELS (injectés par le contrôleur) ── -->
                <VBox fx:id="carouselContainer" spacing="32" styleClass="carousel-container" />

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
