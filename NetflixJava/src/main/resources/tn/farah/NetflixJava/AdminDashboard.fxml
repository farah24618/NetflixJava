<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.farah.NetflixJava.Controller.AdminDashboardController"
            prefWidth="1400.0"
            prefHeight="850.0"
            style="-fx-background-color: #141414;">

    <!-- TOP BAR -->
    <top>
        <HBox alignment="CENTER_LEFT"
              spacing="20.0"
              prefHeight="70.0"
              style="-fx-background-color: #0f0f0f;">
            <padding>
                <Insets top="15" right="25" bottom="15" left="25"/>
            </padding>

            <children>
                <Label text="RAKCHANET ADMIN"
                       style="-fx-text-fill: #E50914; -fx-font-size: 26px; -fx-font-weight: bold;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Label fx:id="lblAdminName"
                       text="Bienvenue Admin"
                       style="-fx-text-fill: white; -fx-font-size: 15px;"/>

                <Button text="Déconnexion"
                        onAction="#handleLogout"
                        style="-fx-background-color: #E50914; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6;"/>
            </children>
        </HBox>
    </top>

    <!-- LEFT MENU -->
    <left>
        <VBox spacing="15.0"
              prefWidth="230.0"
              style="-fx-background-color: #1b1b1b;">
            <padding>
                <Insets top="25" right="15" bottom="25" left="15"/>
            </padding>

            <children>
                <Label text="Menu"
                       style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>

                <Button text="Tableau de bord"
                        style="-fx-background-color: #2a2a2a; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 6;"/>

                <Button text="Gérer les films"
                        onAction="#goToFilmsAdmin"
                        style="-fx-background-color: transparent; -fx-text-fill: #cccccc; -fx-font-size: 14px;"/>

                <Button text="Gérer les séries"
                        onAction="#goToSeriesAdmin"
                        style="-fx-background-color: transparent; -fx-text-fill: #cccccc; -fx-font-size: 14px;"/>

                <Button text="Gérer les épisodes"
                        onAction="#goToEpisodesAdmin"
                        style="-fx-background-color: transparent; -fx-text-fill: #cccccc; -fx-font-size: 14px;"/>

                <Button text="Gérer les utilisateurs"
                        onAction="#goToUsersAdmin"
                        style="-fx-background-color: transparent; -fx-text-fill: #cccccc; -fx-font-size: 14px;"/>

                <Button text="Gérer les commentaires"
                        onAction="#goToCommentsAdmin"
                        style="-fx-background-color: transparent; -fx-text-fill: #cccccc; -fx-font-size: 14px;"/>
            </children>
        </VBox>
    </left>

    <!-- CENTER CONTENT -->
    <center>
        <VBox spacing="25.0" style="-fx-background-color: #141414;">
            <padding>
                <Insets top="25" right="25" bottom="25" left="25"/>
            </padding>

            <children>
                <Label text="Tableau de bord"
                       style="-fx-text-fill: white; -fx-font-size: 30px; -fx-font-weight: bold;"/>

                <!-- Cards statistiques -->
                <GridPane hgap="20.0" vgap="20.0">
                    <children>
                        <VBox GridPane.rowIndex="0" GridPane.columnIndex="0"
                              spacing="10.0"
                              prefWidth="220.0"
                              prefHeight="120.0"
                              style="-fx-background-color: #1f1f1f; -fx-background-radius: 12; -fx-padding: 20;">
                            <children>
                                <Label text="Films"
                                       style="-fx-text-fill: #aaaaaa; -fx-font-size: 16px;"/>
                                <Label fx:id="lblNbFilms"
                                       text="0"
                                       style="-fx-text-fill: white; -fx-font-size: 34px; -fx-font-weight: bold;"/>
                            </children>
                        </VBox>

                        <VBox GridPane.rowIndex="0" GridPane.columnIndex="1"
                              spacing="10.0"
                              prefWidth="220.0"
                              prefHeight="120.0"
                              style="-fx-background-color: #1f1f1f; -fx-background-radius: 12; -fx-padding: 20;">
                            <children>
                                <Label text="Séries"
                                       style="-fx-text-fill: #aaaaaa; -fx-font-size: 16px;"/>
                                <Label fx:id="lblNbSeries"
                                       text="0"
                                       style="-fx-text-fill: white; -fx-font-size: 34px; -fx-font-weight: bold;"/>
                            </children>
                        </VBox>

                        <VBox GridPane.rowIndex="0" GridPane.columnIndex="2"
                              spacing="10.0"
                              prefWidth="220.0"
                              prefHeight="120.0"
                              style="-fx-background-color: #1f1f1f; -fx-background-radius: 12; -fx-padding: 20;">
                            <children>
                                <Label text="Utilisateurs"
                                       style="-fx-text-fill: #aaaaaa; -fx-font-size: 16px;"/>
                                <Label fx:id="lblNbUsers"
                                       text="0"
                                       style="-fx-text-fill: white; -fx-font-size: 34px; -fx-font-weight: bold;"/>
                            </children>
                        </VBox>

                        <VBox GridPane.rowIndex="0" GridPane.columnIndex="3"
                              spacing="10.0"
                              prefWidth="220.0"
                              prefHeight="120.0"
                              style="-fx-background-color: #1f1f1f; -fx-background-radius: 12; -fx-padding: 20;">
                            <children>
                                <Label text="Commentaires"
                                       style="-fx-text-fill: #aaaaaa; -fx-font-size: 16px;"/>
                                <Label fx:id="lblNbComments"
                                       text="0"
                                       style="-fx-text-fill: white; -fx-font-size: 34px; -fx-font-weight: bold;"/>
                            </children>
                        </VBox>
                    </children>
                </GridPane>

                <!-- Actions rapides -->
                <VBox spacing="15.0"
                      style="-fx-background-color: #1b1b1b; -fx-background-radius: 12; -fx-padding: 20;">
                    <children>
                        <Label text="Actions rapides"
                               style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>

                        <HBox spacing="15.0">
                            <children>
                                <Button text="Ajouter un film"
                                        onAction="#goToFilmsAdmin"
                                        style="-fx-background-color: #E50914; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6;"/>

                                <Button text="Ajouter une série"
                                        onAction="#goToSeriesAdmin"
                                        style="-fx-background-color: #2a2a2a; -fx-text-fill: white; -fx-background-radius: 6;"/>

                                <Button text="Gérer les utilisateurs"
                                        onAction="#goToUsersAdmin"
                                        style="-fx-background-color: #2a2a2a; -fx-text-fill: white; -fx-background-radius: 6;"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>

            </children>
        </VBox>
    </center>

</BorderPane>