<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="650.0" prefWidth="1000.0" style="-fx-background-color: rgba(0,0,0,0.85);" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.farah.NetflixJava.Controller.CommentListController">
   <children>
      <VBox maxHeight="550.0" maxWidth="600.0" style="-fx-background-color: #181818; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.6), 30, 0, 0, 0);">
         <children>
            
            <HBox alignment="CENTER_LEFT">
               <padding>
                  <Insets bottom="15.0" left="25.0" right="25.0" top="20.0" />
               </padding>
               <children>
                  <VBox spacing="2">
                     <children>
                        <Label fx:id="filmTitleLabel" text="Comments for Film" textFill="WHITE">
                           <font>
                              <Font name="System Bold" size="20.0" />
                           </font>
                        </Label>
                        <Label fx:id="commentCountLabel" text="Comments (0)" textFill="#888888">
                           <font>
                              <Font size="13.0" />
                           </font>
                        </Label>
                     </children>
                  </VBox>
                  <Region HBox.hgrow="ALWAYS" />
                  <Button onAction="#handleClose" style="-fx-background-color: transparent; -fx-text-fill: #aaaaaa; -fx-cursor: hand;" text="✕">
                     <font>
                        <Font name="System Bold" size="18.0" />
                     </font>
                  </Button>
               </children>
            </HBox>

            <Separator opacity="0.05" />

            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS">
               <content>
                  <VBox fx:id="commentsContainer" prefHeight="-1.0" spacing="10.0" style="-fx-background-color: #181818;">
                     <padding>
                        <Insets bottom="20.0" left="25.0" right="25.0" top="10.0" />
                     </padding>
                  </VBox>
               </content>
            </ScrollPane>

            <Separator opacity="0.05" />

            <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: #202020; -fx-background-radius: 0 0 12 12;">
               <padding>
                  <Insets bottom="20.0" left="25.0" right="25.0" top="20.0" />
               </padding>
               <children>
                  <TextField fx:id="commentInput" promptText="Add a comment..." HBox.hgrow="ALWAYS" style="-fx-background-color: #2b2b2b; -fx-text-fill: white; -fx-prompt-text-fill: #666666; -fx-background-radius: 5; -fx-padding: 10;" />
                  <Button onAction="#handlePostComment" style="-fx-background-color: #E50914; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-cursor: hand; -fx-background-radius: 5;" text="Post" />
               </children>
            </HBox>
            
         </children>
      </VBox>
   </children>
</StackPane>