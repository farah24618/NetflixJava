                        <Label fx:id="prixLabel" style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;" text="prix" />
                     </children>
                  </HBox>

                  <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleCommencerAbonnement" style="-fx-background-color: #E50914; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-pref-height: 50; -fx-background-radius: 4;" text="COMMENCER MON ABONNEMENT" />
                  
                  <Label alignment="CENTER" maxWidth="1.7976931348623157E308" style="-fx-text-fill: #666666; -fx-font-size: 11px;" text="Paiement sécurisé · Annulation à tout moment" />
