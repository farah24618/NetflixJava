                  <Image url="@ImagesNet/netflixLogo.jpg" />
               </image>
            </ImageView>
            <Region HBox.hgrow="ALWAYS" />
            <Button mnemonicParsing="false" onAction="#handleRetour" style="-fx-background-color: #E50914; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 4; -fx-padding: 7 15;" text="retour" />
         </children>
      </HBox>
   </top>

   <center>
      <VBox alignment="CENTER" BorderPane.alignment="CENTER">
