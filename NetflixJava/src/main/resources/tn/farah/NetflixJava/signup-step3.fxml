                                 <children>
                                    <Label style="-fx-text-fill: #aaaaaa; -fx-font-size: 11px; -fx-font-weight: bold;" text="DATE D'EXPIRATION" />
                                    <TextField promptText="MM / AA" style="-fx-background-color: #1a1a1a; -fx-border-color: #444444; -fx-text-fill: white; -fx-prompt-text-fill: #555555; -fx-pref-height: 45; -fx-background-radius: 4; -fx-border-radius: 4;" />
                                 </children>
                              </VBox>
                              <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label style="-fx-text-fill: #aaaaaa; -fx-font-size: 11px; -fx-font-weight: bold;" text="CODE CVV" />
                                    <TextField promptText="..." style="-fx-background-color: #1a1a1a; -fx-border-color: #444444; -fx-text-fill: white; -fx-prompt-text-fill: #555555; -fx-pref-height: 45; -fx-background-radius: 4; -fx-border-radius: 4;" />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                        <VBox spacing="5.0">
                           <children>
                              <Label style="-fx-text-fill: #aaaaaa; -fx-font-size: 11px; -fx-font-weight: bold;" text="NOM SUR LA CARTE" />
                              <TextField promptText="Prénom Nom" style="-fx-background-color: #1a1a1a; -fx-border-color: #444444; -fx-text-fill: white; -fx-prompt-text-fill: #555555; -fx-pref-height: 45; -fx-background-radius: 4; -fx-border-radius: 4;" />
                           </children>
                        </VBox>
                     </children>
                  </VBox>

                  <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #1a1a1a; -fx-border-color: #333333; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 15;">
