<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane prefHeight="900" prefWidth="1100"
            style="-fx-background-color: #141414;"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.farah.NetflixJava.Controller.EpisodeViewController">

    <!-- ===================================================== -->
    <!-- NAVBAR                                                  -->
    <!-- ===================================================== -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="30"
              style="-fx-background-color: #141414; -fx-padding: 15 30 15 30;">

            <Label style="-fx-text-fill: #E50914; -fx-font-size: 28px; -fx-font-weight: bold;"
                   text="NETFLIX" />

            <HBox spacing="20">
                <Label style="-fx-text-fill: white;   -fx-font-size: 14px; -fx-cursor: hand;" text="Accueil" />
                <Label style="-fx-text-fill: #aaaaaa; -fx-font-size: 14px; -fx-cursor: hand;" text="Séries" />
                <Label style="-fx-text-fill: #aaaaaa; -fx-font-size: 14px; -fx-cursor: hand;" text="Films" />
                <Label style="-fx-text-fill: #aaaaaa; -fx-font-size: 14px; -fx-cursor: hand;" text="Ma Liste" />
            </HBox>

            <HBox HBox.hgrow="ALWAYS" />

            <TextField fx:id="searchField" prefWidth="240" promptText="Rechercher..."
                       style="-fx-background-color: #333333; -fx-text-fill: white;
                              -fx-prompt-text-fill: #888888; -fx-padding: 6 12 6 12;
                              -fx-background-radius: 4;" />

            <!-- PROFIL UTILISATEUR -->
            <HBox fx:id="profilBox" alignment="CENTER" spacing="10"
                  onMouseClicked="#onProfilClicked"
                  style="-fx-cursor: hand; -fx-padding: 4 10 4 10;
                         -fx-background-color: #1f1f1f;
                         -fx-background-radius: 8;">

                <Label fx:id="labelUserName"
                       style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;"
                       text="Utilisateur" />

                <StackPane fx:id="avatarContainer" prefWidth="38" prefHeight="38">
                    <ImageView fx:id="avatarImage"
                               fitWidth="38" fitHeight="38"
                               preserveRatio="false" smooth="true">
                        <clip>
                            <Rectangle width="38" height="38" arcWidth="8" arcHeight="8"/>
                        </clip>
                    </ImageView>
                    <StackPane fx:id="avatarFallback" prefWidth="38" prefHeight="38"
                               style="-fx-background-color: #E50914; -fx-background-radius: 8;">
                        <Label fx:id="avatarInitiale"
                               style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px;"
                               text="U" />
                    </StackPane>
                </StackPane>

                <Label style="-fx-text-fill: #aaaaaa; -fx-font-size: 11px;" text="▼" />
            </HBox>

        </HBox>
    </top>

    <!-- ===================================================== -->
    <!-- CONTENU PRINCIPAL                                       -->
    <!-- ===================================================== -->
    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background: #141414; -fx-background-color: #141414;
                           -fx-border-color: transparent;">
            <content>
                <VBox spacing="0">

                    <!-- ============================================= -->
                    <!-- PLAYER VIDÉO                                   -->
                    <!-- ============================================= -->
                    <StackPane fx:id="videoPane" prefHeight="520"
                               style="-fx-background-color: #000000;">

                        <!-- Zone centrale du player -->
                        <VBox alignment="CENTER" spacing="12"
                              style="-fx-background-color: #0d0d0d;"
                              StackPane.alignment="CENTER">
                            <Label style="-fx-text-fill: white; -fx-font-size: 60px; -fx-opacity: 0.3;"
                                   text="▶" />
                            <Label fx:id="episodeTitleVideo"
                                   style="-fx-text-fill: #aaaaaa; -fx-font-size: 16px;"
                                   text="S01 E04 — L'Échange" />
                        </VBox>

                        <!-- Contrôles player (bas) -->
                        <VBox spacing="8" style="-fx-padding: 20 30 20 30;"
                              StackPane.alignment="BOTTOM_CENTER">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label fx:id="currentTime"
                                       style="-fx-text-fill: white; -fx-font-size: 12px;"
                                       text="13:00" />
                                <Slider fx:id="progressSlider" min="0" max="100" value="23"
                                        style="-fx-accent: #E50914;"
                                        HBox.hgrow="ALWAYS" />
                                <Label fx:id="totalTime"
                                       style="-fx-text-fill: white; -fx-font-size: 12px;"
                                       text="56:00" />
                            </HBox>
                            <HBox alignment="CENTER_LEFT" spacing="16">
                                <Button fx:id="btnPlayPause" onAction="#onPlayPause" text="⏸"
                                        style="-fx-background-color: transparent; -fx-text-fill: white;
                                               -fx-font-size: 22px; -fx-cursor: hand;" />
                                <Button fx:id="btnRewind"    onAction="#onRewind"    text="⏪"
                                        style="-fx-background-color: transparent; -fx-text-fill: white;
                                               -fx-font-size: 18px; -fx-cursor: hand;" />
                                <Button fx:id="btnForward"   onAction="#onForward"   text="⏩"
                                        style="-fx-background-color: transparent; -fx-text-fill: white;
                                               -fx-font-size: 18px; -fx-cursor: hand;" />
                                <Label fx:id="currentTimeSmall"
                                       style="-fx-text-fill: white; -fx-font-size: 13px;"
                                       text="13:00 / 56:00" />
                                <HBox HBox.hgrow="ALWAYS" />
                                <Button fx:id="btnSubtitles" onAction="#onSubtitles" text="CC"
                                        style="-fx-background-color: transparent; -fx-text-fill: white;
                                               -fx-font-size: 14px; -fx-cursor: hand;
                                               -fx-border-color: white; -fx-border-radius: 3;
                                               -fx-padding: 2 6 2 6;" />
                                <Button fx:id="btnVolume"    onAction="#onVolume"    text="Vol"
                                        style="-fx-background-color: transparent; -fx-text-fill: white;
                                               -fx-font-size: 14px; -fx-cursor: hand;" />
                                <Slider fx:id="volumeSlider" min="0" max="100" value="80"
                                        prefWidth="80" style="-fx-accent: white;" />
                                <Button fx:id="btnFullscreen" onAction="#onFullscreen" text="[ ]"
                                        style="-fx-background-color: transparent; -fx-text-fill: white;
                                               -fx-font-size: 14px; -fx-cursor: hand;" />
                            </HBox>
                        </VBox>

                        <!-- Bouton passer l'intro -->
                        <Button fx:id="btnSkipIntro" onAction="#onSkipIntro"
                                text="Passer l'intro"
                                StackPane.alignment="BOTTOM_RIGHT"
                                style="-fx-background-color: transparent; -fx-text-fill: white;
                                       -fx-border-color: white; -fx-border-radius: 4;
                                       -fx-background-radius: 4; -fx-font-size: 13px;
                                       -fx-padding: 8 16 8 16; -fx-cursor: hand;">
                            <StackPane.margin>
                                <Insets bottom="80" right="30" />
                            </StackPane.margin>
                        </Button>

                    </StackPane>

                    <!-- ============================================= -->
                    <!-- INFOS ÉPISODE + DISTRIBUTION                  -->
                    <!-- ============================================= -->
                    <HBox spacing="30" style="-fx-padding: 24 30 10 30;">

                        <VBox spacing="10" HBox.hgrow="ALWAYS">

                            <!-- Fil d'ariane -->
<HBox alignment="CENTER_LEFT" spacing="12">
    <Label style="-fx-text-fill: #aaaaaa; -fx-font-size: 13px; -fx-cursor: hand;"
           text="TitreSerie" />
    <Label style="-fx-text-fill: #555555; -fx-font-size: 13px;" text="›" />
    <Label style="-fx-text-fill: #aaaaaa; -fx-font-size: 13px; -fx-cursor: hand;"
           text="Saison " />
    <Label fx:id="labelNumeroSaison"
           style="-fx-text-fill: #aaaaaa; -fx-font-size: 13px;"
           text="1" />
    <Label style="-fx-text-fill: #555555; -fx-font-size: 13px;" text="›" />
    <Label style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;"
           text="Episode " />
    <Label fx:id="labelNumeroEpisode"
           style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;"
           text="4" />
</HBox>

<!-- Titre épisode -->
<Label fx:id="episodeTitle"
       style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;"
       text="TitreEpisode" />

<!-- Métadonnées -->
<HBox alignment="CENTER_LEFT" spacing="12">
    <Label fx:id="labelSaisonEpisode"
           style="-fx-text-fill: #aaaaaa; -fx-font-size: 13px;"
           text="Saison 1 - Episode 4" />
    <Label style="-fx-text-fill: #555555;" text="|" />
    <Label fx:id="labelDuree"
           style="-fx-text-fill: #aaaaaa; -fx-font-size: 13px;"
           text="56 min" />
    <Label style="-fx-text-fill: #555555;" text="|" />
    <Label fx:id="labelDateSortie"
           style="-fx-text-fill: #aaaaaa; -fx-font-size: 13px;"
           text="2024" />
    <Label style="-fx-text-fill: white; -fx-font-size: 11px;
                  -fx-background-color: #555555;
                  -fx-padding: 2 6 2 6; -fx-background-radius: 3;"
           text="16+" />
</HBox>

<!-- Description -->
<Label fx:id="episodeDesc" maxWidth="620" wrapText="true"
       style="-fx-text-fill: #cccccc; -fx-font-size: 14px;"
       text="resume" />
                            <!-- Boutons actions -->
                            <HBox spacing="12" style="-fx-padding: 8 0 0 0;">
                                <Button fx:id="btnLike"     onAction="#onLike"
                                        text="J'aime"
                                        style="-fx-background-color: #333333; -fx-text-fill: white;
                                               -fx-padding: 8 18 8 18; -fx-background-radius: 4;
                                               -fx-cursor: hand; -fx-font-size: 13px;" />
                                <Button fx:id="btnDislike"  onAction="#onDislike"
                                        text="Je n'aime pas"
                                        style="-fx-background-color: #333333; -fx-text-fill: white;
                                               -fx-padding: 8 18 8 18; -fx-background-radius: 4;
                                               -fx-cursor: hand; -fx-font-size: 13px;" />
                                <Button fx:id="btnShare"    onAction="#onShare"
                                        text="Partager"
                                        style="-fx-background-color: #333333; -fx-text-fill: white;
                                               -fx-padding: 8 18 8 18; -fx-background-radius: 4;
                                               -fx-cursor: hand; -fx-font-size: 13px;" />
                                <Button fx:id="btnDownload" onAction="#onDownload"
                                        text="Telecharger"
                                        style="-fx-background-color: #333333; -fx-text-fill: white;
                                               -fx-padding: 8 18 8 18; -fx-background-radius: 4;
                                               -fx-cursor: hand; -fx-font-size: 13px;" />
                            </HBox>
                        </VBox>

                        <!-- Distribution -->
                        <VBox prefWidth="260" spacing="10"
                              style="-fx-background-color: #1f1f1f; -fx-padding: 16;
                                     -fx-background-radius: 6;">
                            <Label style="-fx-text-fill: white; -fx-font-weight: bold;
                                          -fx-font-size: 14px;" text="Distribution" />
                            <VBox fx:id="castList" spacing="10" />
                        </VBox>

                    </HBox>

                    <!-- ============================================= -->
                    <!-- BARRE ONGLETS                                  -->
                    <!-- ============================================= -->
                    <HBox alignment="CENTER_LEFT" spacing="0"
                          style="-fx-background-color: #141414;
                                 -fx-border-color: transparent transparent #333333 transparent;
                                 -fx-border-width: 0 0 1 0;
                                 -fx-padding: 10 30 0 30;">

                        <VBox fx:id="tabApropos" alignment="CENTER"
                              onMouseClicked="#onTabApropos"
                              style="-fx-padding: 14 20 0 20; -fx-cursor: hand;">
                            <Label style="-fx-text-fill: #aaaaaa; -fx-font-size: 14px;" text="À propos" />
                            <HBox prefHeight="3" prefWidth="0"
                                  style="-fx-background-color: transparent; -fx-padding: 10 0 0 0;" />
                        </VBox>

                        <VBox fx:id="tabEpisodes" alignment="CENTER"
                              onMouseClicked="#onTabEpisodes"
                              style="-fx-padding: 14 20 0 20; -fx-cursor: hand;">
                            <Label style="-fx-text-fill: white; -fx-font-size: 14px;
                                          -fx-font-weight: bold;" text="Épisodes" />
                            <HBox prefHeight="3"
                                  style="-fx-background-color: #E50914;
                                         -fx-background-radius: 2 2 0 0;
                                         -fx-padding: 10 0 0 0;"
                                  HBox.hgrow="ALWAYS" />
                        </VBox>

                        <VBox fx:id="tabBandes" alignment="CENTER"
                              onMouseClicked="#onTabBandes"
                              style="-fx-padding: 14 20 0 20; -fx-cursor: hand;">
                            <Label style="-fx-text-fill: #aaaaaa; -fx-font-size: 14px;"
                                   text="Bandes-annonces" />
                            <HBox prefHeight="3" prefWidth="0"
                                  style="-fx-background-color: transparent; -fx-padding: 10 0 0 0;" />
                        </VBox>

                        <VBox fx:id="tabCommentaires" alignment="CENTER"
                              onMouseClicked="#onTabCommentaires"
                              style="-fx-padding: 14 20 0 20; -fx-cursor: hand;">
                            <Label style="-fx-text-fill: #aaaaaa; -fx-font-size: 14px;"
                                   text="Commentaires" />
                            <HBox prefHeight="3" prefWidth="0"
                                  style="-fx-background-color: transparent; -fx-padding: 10 0 0 0;" />
                        </VBox>

                        <VBox fx:id="tabSimilaires" alignment="CENTER"
                              onMouseClicked="#onTabSimilaires"
                              style="-fx-padding: 14 20 0 20; -fx-cursor: hand;">
                            <Label style="-fx-text-fill: #aaaaaa; -fx-font-size: 14px;"
                                   text="Similaires" />
                            <HBox prefHeight="3" prefWidth="0"
                                  style="-fx-background-color: transparent; -fx-padding: 10 0 0 0;" />
                        </VBox>

                    </HBox>

                    <!-- ============================================= -->
                    <!-- ZONE CONTENU ONGLETS                          -->
                    <!-- ============================================= -->
                    <VBox fx:id="contenuOnglet" spacing="0"
                          style="-fx-padding: 20 30 30 30;">

                        <!-- ───── ONGLET ÉPISODES ───── -->
                        <VBox fx:id="panelEpisodes" spacing="16"
                              visible="true" managed="true">
                            <HBox alignment="CENTER_LEFT" spacing="16">
                                <Label style="-fx-text-fill: white; -fx-font-size: 18px;
                                              -fx-font-weight: bold;" text="Saison 1" />
                                <Label style="-fx-text-fill: #aaaaaa; -fx-font-size: 13px;"
                                       text="10 épisodes" />
                            </HBox>
                            <VBox fx:id="listeEpisodes" spacing="12" />
                        </VBox>

                        <!-- ───── ONGLET À PROPOS ───── -->
                        <VBox fx:id="panelApropos" spacing="14"
                              visible="false" managed="false">
                            <Label style="-fx-text-fill: white; -fx-font-size: 18px;
                                          -fx-font-weight: bold;" text="À propos de la série" />
                            <Label style="-fx-text-fill: #cccccc; -fx-font-size: 14px;"
                                   text="Une série haletante qui plonge le spectateur dans les méandres du pouvoir et de la trahison."
                                   wrapText="true" />
                            <HBox spacing="30" style="-fx-padding: 10 0 0 0;">
                                <VBox spacing="6">
                                    <Label style="-fx-text-fill: #aaaaaa; -fx-font-size: 12px;"
                                           text="CRÉATEUR" />
                                    <Label style="-fx-text-fill: white; -fx-font-size: 14px;"
                                           text="Farah Ben Ali" />
                                </VBox>
                                <VBox spacing="6">
                                    <Label style="-fx-text-fill: #aaaaaa; -fx-font-size: 12px;"
                                           text="GENRE" />
                                    <Label style="-fx-text-fill: white; -fx-font-size: 14px;"
                                           text="Thriller, Drame" />
                                </VBox>
                                <VBox spacing="6">
                                    <Label style="-fx-text-fill: #aaaaaa; -fx-font-size: 12px;"
                                           text="ANNÉE" />
                                    <Label style="-fx-text-fill: white; -fx-font-size: 14px;"
                                           text="2024" />
                                </VBox>
                            </HBox>
                        </VBox>

                        <!-- ───── ONGLET BANDES-ANNONCES ───── -->
                        <VBox fx:id="panelBandes" spacing="14"
                              visible="false" managed="false">
                            <Label style="-fx-text-fill: white; -fx-font-size: 18px;
                                          -fx-font-weight: bold;" text="Bandes-annonces" />
                            <HBox spacing="16">
                                <StackPane prefWidth="280" prefHeight="158"
                                           style="-fx-background-color: #2a2a2a;
                                                  -fx-background-radius: 6; -fx-cursor: hand;">
                                    <Label style="-fx-text-fill: white; -fx-font-size: 40px;
                                                  -fx-opacity: 0.5;" text="▶" />
                                    <Label style="-fx-text-fill: #aaaaaa; -fx-font-size: 13px;"
                                           text="Bande-annonce officielle"
                                           StackPane.alignment="BOTTOM_LEFT">
                                        <StackPane.margin>
                                            <Insets bottom="12" left="12" />
                                        </StackPane.margin>
                                    </Label>
                                </StackPane>
                                <StackPane prefWidth="280" prefHeight="158"
                                           style="-fx-background-color: #2a2a2a;
                                                  -fx-background-radius: 6; -fx-cursor: hand;">
                                    <Label style="-fx-text-fill: white; -fx-font-size: 40px;
                                                  -fx-opacity: 0.5;" text="▶" />
                                    <Label style="-fx-text-fill: #aaaaaa; -fx-font-size: 13px;"
                                           text="Teaser Saison 1"
                                           StackPane.alignment="BOTTOM_LEFT">
                                        <StackPane.margin>
                                            <Insets bottom="12" left="12" />
                                        </StackPane.margin>
                                    </Label>
                                </StackPane>
                            </HBox>
                        </VBox>

                        <!-- ───── ONGLET SIMILAIRES ───── -->
                        <VBox fx:id="panelSimilaires" spacing="14"
                              visible="false" managed="false">
                            <Label style="-fx-text-fill: white; -fx-font-size: 18px;
                                          -fx-font-weight: bold;" text="Séries similaires" />
                            <HBox fx:id="listeSimilaires" spacing="16" />
                        </VBox>

                        <!-- ───── ONGLET COMMENTAIRES (collègue) ───── -->
                        <!-- Rien ici : géré par votre collègue -->

                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>