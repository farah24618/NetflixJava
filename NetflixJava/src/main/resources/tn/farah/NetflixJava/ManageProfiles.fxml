<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            prefWidth="900.0"
            prefHeight="700.0"
            style="-fx-background-color: #141414;">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="15.0"
              style="-fx-background-color: #141414;">
            <padding>
                <Insets top="15.0" right="25.0" bottom="10.0" left="25.0"/>
            </padding>
            <children>
                <ImageView fitHeight="40.0" preserveRatio="true">
                    <image>
                        <Image url="@ImagesNet/log5.jpg"/>
                    </image>
                </ImageView>
            </children>
        </HBox>
    </top>

    <center>
        <VBox spacing="18.0"
              prefWidth="700.0"
              maxWidth="700.0"
              BorderPane.alignment="CENTER">
            <padding>
                <Insets top="25.0" right="25.0" bottom="25.0" left="25.0"/>
            </padding>

            <children>

                <Label text="Edit Profile"
                       style="-fx-text-fill: white; -fx-font-size: 44px;"/>

                <Separator style="-fx-background-color: #333333;"/>

                <HBox spacing="20.0" alignment="TOP_LEFT">
                    <children>

                        <ImageView fitWidth="110.0" fitHeight="110.0" preserveRatio="false">
                            <image>
                                <Image url="@ImagesNet/log5.jpg"/>
                            </image>
                        </ImageView>

                        <VBox spacing="16.0">
                            <children>

                                <TextField promptText="Nom du profil"
                                           text="Joline"
                                           prefWidth="420.0"
                                           style="-fx-background-color: #666666; -fx-text-fill: white; -fx-prompt-text-fill: #cccccc; -fx-font-size: 22px;"/>

                                <VBox spacing="8.0">
                                    <children>
                                        <Label text="Language:"
                                               style="-fx-text-fill: white; -fx-font-size: 16px;"/>
                                        <ComboBox prefWidth="140.0"
                                                  style="-fx-background-color: black; -fx-font-size: 14px;"/>
                                    </children>
                                </VBox>

                                <VBox spacing="8.0">
                                    <children>
                                        <Label text="Game Handle:"
                                               style="-fx-text-fill: white; -fx-font-size: 16px;"/>
                                        <Label text="Your handle is a unique name that’ll be used for playing with other members across all Netflix Games."
                                               wrapText="true"
                                               maxWidth="430.0"
                                               style="-fx-text-fill: #B3B3B3; -fx-font-size: 13px;"/>
                                        <TextField promptText="Create Game Handle"
                                                   prefWidth="420.0"
                                                   style="-fx-background-color: #666666; -fx-text-fill: white; -fx-prompt-text-fill: #d0d0d0; -fx-font-size: 18px;"/>
                                    </children>
                                </VBox>

                            </children>
                        </VBox>
                    </children>
                </HBox>

                <Separator style="-fx-background-color: #333333;"/>

                <VBox spacing="10.0">
                    <children>
                        <Label text="Maturity Settings:"
                               style="-fx-text-fill: white; -fx-font-size: 18px;"/>
                        <Label text="All Maturity Ratings"
                               style="-fx-background-color: #333333; -fx-text-fill: white; -fx-padding: 8 12 8 12; -fx-font-size: 14px;"/>
                        <Label text="Show titles of all maturity ratings for this profile."
                               wrapText="true"
                               style="-fx-text-fill: #B3B3B3; -fx-font-size: 14px;"/>
                        <Button text="Edit"
                                prefWidth="90.0"
                                style="-fx-background-color: transparent; -fx-border-color: #666666; -fx-text-fill: #B3B3B3; -fx-font-size: 14px;"/>
                    </children>
                </VBox>

                <Separator style="-fx-background-color: #333333;"/>

                <VBox spacing="12.0">
                    <children>
                        <Label text="Autoplay controls"
                               style="-fx-text-fill: white; -fx-font-size: 18px;"/>

                        <CheckBox text="Autoplay next episode in a series on all devices."
                                  selected="true"
                                  style="-fx-text-fill: white; -fx-font-size: 14px;"/>

                        <CheckBox text="Autoplay previews while browsing on all devices."
                                  selected="true"
                                  style="-fx-text-fill: white; -fx-font-size: 14px;"/>
                    </children>
                </VBox>

                <Separator style="-fx-background-color: #333333;"/>

                <HBox spacing="18.0" alignment="CENTER_LEFT">
                    <children>

                        <Button text="Save"
                                prefWidth="120.0"
                                prefHeight="42.0"
                                style="-fx-background-color: white; -fx-text-fill: black; -fx-font-size: 18px; -fx-font-weight: bold;"/>

                        <Button text="Cancel"
                                prefWidth="120.0"
                                prefHeight="42.0"
                                style="-fx-background-color: transparent; -fx-border-color: #666666; -fx-text-fill: #B3B3B3; -fx-font-size: 18px;"/>

                        <Button text="Delete Profile"
                                prefWidth="180.0"
                                prefHeight="42.0"
                                style="-fx-background-color: transparent; -fx-border-color: #666666; -fx-text-fill: #B3B3B3; -fx-font-size: 18px;"/>

                    </children>
                </HBox>

            </children>
        </VBox>
    </center>

</BorderPane>