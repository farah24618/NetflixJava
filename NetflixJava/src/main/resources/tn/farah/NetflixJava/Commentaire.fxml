<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.farah.NetflixJava.Controller.EpisodeCommentsController"
            prefWidth="1000" prefHeight="700"
            style="-fx-background-color: #121212;"
            >

    <!-- HEADER -->
    <top>
        <VBox spacing="15" style="-fx-background-color: #1b1b1b;">
            <padding>
                <Insets top="20" right="25" bottom="15" left="25"/>
            </padding>

            <!-- Infos épisode -->
            <HBox spacing="20" alignment="CENTER_LEFT">
                <StackPane prefWidth="180" prefHeight="100"
                           style="-fx-background-color: #2a2a2a; -fx-background-radius: 10;">
                    <Label text="Image épisode"
                           style="-fx-text-fill: #aaaaaa; -fx-font-size: 16px;"/>
                </StackPane>

                <VBox spacing="8">
                    <Label fx:id="episodeTitleLabel"
                           text="Episode 5 - Le tournant"
                           style="-fx-text-fill: white; -fx-font-size: 26px; -fx-font-weight: bold;"/>

                    <Label fx:id="seriesTitleLabel"
                           text="Nom de la série"
                           style="-fx-text-fill: #cccccc; -fx-font-size: 17px;"/>

                    <Label fx:id="episodeDescriptionLabel"
                           text="Résumé court de l’épisode. Cette zone peut afficher quelques informations importantes sur l’épisode."
                           wrapText="true"
                           maxWidth="700"
                           style="-fx-text-fill: #bdbdbd; -fx-font-size: 14px;"/>
                </VBox>
            </HBox>

            <!-- Barre navigation -->
            <HBox spacing="35" alignment="CENTER_LEFT">
                <VBox spacing="5">
                    <Label text="À propos"
                           style="-fx-text-fill: #cfcfcf; -fx-font-size: 15px;"/>
                    <Region prefHeight="3" prefWidth="60" style="-fx-background-color: transparent;"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Épisode"
                           style="-fx-text-fill: #cfcfcf; -fx-font-size: 15px;"/>
                    <Region prefHeight="3" prefWidth="55" style="-fx-background-color: transparent;"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Bande-annonce"
                           style="-fx-text-fill: #cfcfcf; -fx-font-size: 15px;"/>
                    <Region prefHeight="3" prefWidth="110" style="-fx-background-color: transparent;"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Commentaires"
                           style="-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                    <Region prefHeight="3" prefWidth="100"
                            style="-fx-background-color: #e50914; -fx-background-radius: 5;"/>
                </VBox>
            </HBox>
        </VBox>
    </top>

    <!-- CONTENU -->
    <center>
        <VBox spacing="15">
            <padding>
                <Insets top="20" right="25" bottom="20" left="25"/>
            </padding>

            <Label text="Commentaires"
                   style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;"/>

            <ListView fx:id="commentsListView"
                      VBox.vgrow="ALWAYS"
                      style="-fx-control-inner-background: #121212; -fx-background-color: #121212; -fx-border-color: #2f2f2f; -fx-border-radius: 8;"/>
        </VBox>
    </center>

    <!-- AJOUT COMMENTAIRE -->
    <bottom>
        <VBox spacing="12" style="-fx-background-color: #1b1b1b;">
            <padding>
                <Insets top="18" right="25" bottom="18" left="25"/>
            </padding>

            <Label text="Ajouter un commentaire"
                   style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>

            <TextArea fx:id="commentInputArea"
                      promptText="Écris ton commentaire ici..."
                      wrapText="true"
                      prefRowCount="4"
                      style="-fx-text-fill: white; -fx-control-inner-background: #2a2a2a; -fx-prompt-text-fill: #8f8f8f; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #3a3a3a;"/>

            <HBox spacing="15" alignment="CENTER_LEFT">
                <CheckBox fx:id="spoilerCheckBox"
                          text="Ce commentaire contient un spoiler"
                          style="-fx-text-fill: #d0d0d0;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="Publier"
                        onAction="#handleAddComment"
                        style="-fx-background-color: #e50914; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>