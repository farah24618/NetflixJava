<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane style="-fx-background-color: rgba(0, 0, 0, 0.75);" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.farah.NetflixJava.Controller.OublieController">
   <children>
      <VBox fx:id="mainContainer" alignment="TOP_CENTER" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="550.0" prefWidth="500.0" spacing="15.0" style="-fx-background-color: #141414; -fx-background-radius: 10; -fx-border-color: #333333; -fx-border-radius: 10;">
         <padding>
            <Insets bottom="30.0" left="40.0" right="40.0" top="20.0" />
         </padding>
         <children>
            
            <HBox alignment="CENTER_RIGHT" prefHeight="30.0" prefWidth="200.0">
               <children>
                  <Label onMouseClicked="#handleClose" style="-fx-font-size: 20px;" text="✕" textFill="#b3b3b3">
                     <cursor>
                        <Cursor fx:constant="HAND" />
                     </cursor>
                  </Label>
               </children>
            </HBox>

            <Label style="-fx-font-size: 28px; -fx-font-weight: bold;" text="Forgot Password?" textFill="WHITE" />

            <Label fx:id="instructionLabel" style="-fx-font-size: 14px;" text="A reset email will be sent to your address" textFill="#cccccc" />

            <VBox fx:id="emailSection" spacing="8.0">
               <children>
                  <Label style="-fx-font-size: 14px;" text="Email Address" textFill="#b3b3b3" />
                  <TextField fx:id="emailField" style="-fx-background-color: #333333; -fx-text-fill: white; -fx-font-size: 16px; -fx-padding: 12; -fx-background-radius: 5;" />
               </children>
            </VBox>

            <VBox fx:id="codeContainer" alignment="CENTER" managed="false" spacing="15.0" visible="false">
               <children>
                  <Label style="-fx-font-size: 14px; -fx-font-weight: bold;" text="Enter the 4-digit code" textFill="#e50914" />
                  <HBox alignment="CENTER" spacing="15.0">
                     <children>
                        <TextField fx:id="code1" alignment="CENTER" prefHeight="50.0" prefWidth="50.0" style="-fx-background-color: #333333; -fx-text-fill: white; -fx-font-size: 20px; -fx-background-radius: 5; -fx-border-color: #555555;" />
                        <TextField fx:id="code2" alignment="CENTER" prefHeight="50.0" prefWidth="50.0" style="-fx-background-color: #333333; -fx-text-fill: white; -fx-font-size: 20px; -fx-background-radius: 5; -fx-border-color: #555555;" />
                        <TextField fx:id="code3" alignment="CENTER" prefHeight="50.0" prefWidth="50.0" style="-fx-background-color: #333333; -fx-text-fill: white; -fx-font-size: 20px; -fx-background-radius: 5; -fx-border-color: #555555;" />
                        <TextField fx:id="code4" alignment="CENTER" prefHeight="50.0" prefWidth="50.0" style="-fx-background-color: #333333; -fx-text-fill: white; -fx-font-size: 20px; -fx-background-radius: 5; -fx-border-color: #555555;" />
                     </children>
                  </HBox>
               </children>
            </VBox>

            <HBox fx:id="captchaBox" alignment="CENTER" maxWidth="350.0" spacing="15.0" style="-fx-background-color: #f9f9f9; -fx-padding: 15 20 15 20; -fx-background-radius: 3; -fx-border-color: #d3d3d3; -fx-border-radius: 3;">
               <children>
                  <CheckBox fx:id="robotCheckBox" mnemonicParsing="false" style="-fx-font-size: 14px; -fx-text-fill: #555555;" text="I'm not a robot">
                     <cursor>
                        <Cursor fx:constant="HAND" />
                     </cursor>
                  </CheckBox>
                  <Region HBox.hgrow="ALWAYS" />
                  <VBox alignment="CENTER">
                     <children>
                        <Label style="-fx-font-size: 24px;" text="♻" textFill="#4a90e2" />
                        <Label style="-fx-font-size: 10px;" text="reCAPTCHA" textFill="#555555" />
                     </children>
                  </VBox>
               </children>
            </HBox>

            <Region VBox.vgrow="ALWAYS" />

            <VBox alignment="CENTER" spacing="15.0">
               <children>
                  <Button fx:id="confirmBtn" maxWidth="350.0" mnemonicParsing="false" onAction="#handleConfirm" style="-fx-background-color: #e50914; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px; -fx-padding: 12; -fx-background-radius: 4;" text="Confirm">
                     <cursor>
                        <Cursor fx:constant="HAND" />
                     </cursor>
                  </Button>

                  <Button maxWidth="350.0" mnemonicParsing="false" onAction="#handleClose" style="-fx-background-color: transparent; -fx-border-color: #555555; -fx-text-fill: #b3b3b3; -fx-font-size: 14px; -fx-padding: 8; -fx-border-radius: 4;" text="CLOSE">
                     <cursor>
                        <Cursor fx:constant="HAND" />
                     </cursor>
                  </Button>
               </children>
            </VBox>

         </children>
      </VBox>
   </children>
</StackPane>